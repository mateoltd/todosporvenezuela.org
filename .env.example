# Public payment configuration. These values render into the static donation modal.
# Use "production" or "sandbox". The active value selects the matching *_PRODUCTION_* or *_SANDBOX_* keys.
PUBLIC_DONATION_ENV=production

PUBLIC_PAYPAL_PRODUCTION_DONATE_URL=https://www.paypal.com/donate
PUBLIC_PAYPAL_PRODUCTION_BUSINESS=
PUBLIC_PAYPAL_PRODUCTION_HOSTED_BUTTON_ID=
PUBLIC_PAYPAL_PRODUCTION_BUTTON_IMAGE_SRC=

PUBLIC_PAYPAL_SANDBOX_DONATE_URL=https://www.sandbox.paypal.com/donate
PUBLIC_PAYPAL_SANDBOX_BUSINESS=
PUBLIC_PAYPAL_SANDBOX_HOSTED_BUTTON_ID=
PUBLIC_PAYPAL_SANDBOX_BUTTON_IMAGE_SRC=

PUBLIC_PAYPAL_BUTTON_IMAGE_ALT=Donate with PayPal button
PUBLIC_PAYPAL_BUTTON_IMAGE_TITLE=PayPal - The safer, easier way to pay online!

PUBLIC_BINANCE_PRODUCTION_PAY_ID=
PUBLIC_BINANCE_SANDBOX_PAY_ID=

PUBLIC_PAGO_MOVIL_PRODUCTION_BANCO=
PUBLIC_PAGO_MOVIL_PRODUCTION_TELEFONO=
PUBLIC_PAGO_MOVIL_PRODUCTION_DOCUMENTO=
PUBLIC_PAGO_MOVIL_PRODUCTION_TITULAR=

PUBLIC_PAGO_MOVIL_SANDBOX_BANCO=
PUBLIC_PAGO_MOVIL_SANDBOX_TELEFONO=
PUBLIC_PAGO_MOVIL_SANDBOX_DOCUMENTO=
PUBLIC_PAGO_MOVIL_SANDBOX_TITULAR=
