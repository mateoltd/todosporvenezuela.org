# Public payment configuration. These values render into the static donation modal.
# Use "production" or "sandbox". The active value selects the matching *_PRODUCTION_* or *_SANDBOX_* keys.
PUBLIC_DONATION_ENV=production
PUBLIC_SITE_URL=https://todosporvenezuela.org
PUBLIC_DONATION_GOAL_USD=800
PUBLIC_DONATION_INITIAL_RAISED_USD=100
PUBLIC_DONATION_PROGRESS_POLL_MS=15000

# Server-side donation progress. Keep these secret in production.
# Use either the UPSTASH_* names or Vercel KV's KV_REST_API_* names.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
UPSTASH_REDIS_REST_READ_ONLY_TOKEN=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
DONATION_REDIS_PREFIX=tpv:donations
DONATION_CURRENCY=USD
DONATION_GOAL_USD=800
DONATION_BASELINE_RAISED_USD=100
DONATION_SSE_INTERVAL_MS=3000
DONATION_SSE_MAX_DURATION_MS=25000
DONATION_ADMIN_TOKEN=

# PayPal IPN verification. The verify URL defaults from PUBLIC_DONATION_ENV, so
# only override PAYPAL_IPN_VERIFY_URL for custom testing.
PAYPAL_IPN_VERIFY_URL=
PAYPAL_RECEIVER_EMAILS=
PAYPAL_RECEIVER_IDS=
DONATION_PAYPAL_ITEM_NAME=Ayuda para insumos médicos, alimentación e hidratación en Venezuela.
DONATION_PAYPAL_ITEM_NUMBER=donacion-terremoto

PUBLIC_PAYPAL_PRODUCTION_DONATE_URL=https://www.paypal.com/donate
PUBLIC_PAYPAL_PRODUCTION_BUSINESS=
PUBLIC_PAYPAL_PRODUCTION_HOSTED_BUTTON_ID=

PUBLIC_PAYPAL_SANDBOX_DONATE_URL=https://www.sandbox.paypal.com/donate
PUBLIC_PAYPAL_SANDBOX_BUSINESS=
PUBLIC_PAYPAL_SANDBOX_HOSTED_BUTTON_ID=

PUBLIC_ORGANIZER_VIDEO_SRC=https://media.mateo.ltd/proj/AQOjGu8elxJIMIT21rU3HW79VS3vEg36BXl1x19_ewzoNvDxVhmaYJl2yWMxY1Vdvc0pwnyg75qRn3ej1DwzRFqtK06kXueZ.mp4
PUBLIC_ORGANIZER_VIDEO_URL=https://www.instagram.com/p/DaD7tL_vjyc/
PUBLIC_ORGANIZER_VIDEO_TITLE=Video de los organizadores de Todos por Venezuela

PUBLIC_BINANCE_PRODUCTION_PAY_ID=
PUBLIC_BINANCE_SANDBOX_PAY_ID=

PUBLIC_PAGO_MOVIL_PRODUCTION_BANCO=
PUBLIC_PAGO_MOVIL_PRODUCTION_TELEFONO=
