---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import AnnouncementBar from "../components/AnnouncementBar.astro";
import DonationModal from "../components/DonationModal.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import {
  getLocaleContent,
  type CampaignContent,
} from "../data/campaign";
import {
  defaultLocale,
  getLocalizedPath,
  localeDefinitions,
  supportedLocales,
  type LanguageSelectorOption,
  type LocalizedRouteKey,
  type SupportedLocale,
} from "../i18n/config";
import { buildDonationConfig } from "../lib/donations/config";

interface AlternateLink {
  hreflang: string;
  href: string;
}

interface Props {
  locale?: SupportedLocale;
  routeKey?: LocalizedRouteKey;
  content?: CampaignContent;
  languageOptions?: LanguageSelectorOption[];
  title: string;
  description: string;
  canonicalUrl?: string;
  alternateLinks?: AlternateLink[];
  robots?: string;
  htmlLang?: string;
  socialTitle?: string;
  socialDescription?: string;
  socialImageUrl: string;
  ogType?: string;
  ogUrl?: string;
  ogLocale?: string;
  twitterDomain?: string;
  twitterUrl?: string;
}

const props = Astro.props;
const currentLocale = props.locale ?? defaultLocale;
const content = props.content ?? getLocaleContent(currentLocale);
const htmlLang = props.htmlLang ?? content.language;
const canonicalUrl = props.canonicalUrl;
const alternateLinks =
  props.alternateLinks ??
  (canonicalUrl
    ? [
        { hreflang: "es", href: canonicalUrl },
        { hreflang: htmlLang, href: canonicalUrl },
        { hreflang: "x-default", href: canonicalUrl },
      ]
    : []);
const robots = props.robots ?? "index, follow, max-image-preview:large";
const socialTitle = props.socialTitle ?? props.title;
const socialDescription = props.socialDescription ?? props.description;
const ogType = props.ogType ?? "website";
const ogLocale = props.ogLocale ?? content.locale;
const ogUrl = props.ogUrl ?? canonicalUrl;
const isSecureSocialImage = props.socialImageUrl.startsWith("https://");
const socialImageTypes: Record<string, string> = {
  jpg: "image/jpeg",
  jpeg: "image/jpeg",
  png: "image/png",
  webp: "image/webp",
};
const socialImageExtension = content.socialImage.path
  .split("?")[0]
  .split(".")
  .pop()
  ?.toLowerCase();
const socialImageType = socialImageExtension
  ? socialImageTypes[socialImageExtension] ?? "image/jpeg"
  : "image/jpeg";
const donation = buildDonationConfig(Astro.url.origin);
const routeKey = props.routeKey ?? "home";
const currentHomePath = getLocalizedPath("home", currentLocale);
const headerLinks = {
  home: currentHomePath,
  impact: `${currentHomePath}#impacto`,
  organizers: `${currentHomePath}#transparencia`,
  transparency: getLocalizedPath("transparency", currentLocale),
  faq: `${currentHomePath}#faq`,
};
const languageOptions: LanguageSelectorOption[] =
  props.languageOptions ??
  supportedLocales.map((locale) => {
    const href = getLocalizedPath(routeKey, locale);
    const definition = localeDefinitions[locale];

    return {
      locale,
      href,
      label: definition.label,
      shortLabel: definition.shortLabel,
    };
  });
const microsoftClarityProjectId = "xduul4uyvv";
const googleAnalyticsMeasurementId = "G-EX089GZ90V";
const microsoftClarityScript = `
    (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", ${JSON.stringify(microsoftClarityProjectId)});
`;
const googleAnalyticsScript = `
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag("js", new Date());

  gtag("config", ${JSON.stringify(googleAnalyticsMeasurementId)});
`;
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="description" content={props.description} />
    <meta name="robots" content={robots} />
    <meta name="author" content={content.siteName} />
    <meta name="theme-color" content="#f7f7f2" />
    <meta name="application-name" content={content.siteName} />
    <title>{props.title}</title>
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {
      alternateLinks.map(({ hreflang, href }) => (
        <link rel="alternate" hreflang={hreflang} href={href} />
      ))
    }
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={content.siteName} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={socialDescription} />
    {ogUrl && <meta property="og:url" content={ogUrl} />}
    <meta property="og:image" content={props.socialImageUrl} />
    {
      isSecureSocialImage && (
        <meta property="og:image:secure_url" content={props.socialImageUrl} />
      )
    }
    <meta property="og:image:type" content={socialImageType} />
    <meta property="og:image:width" content={String(content.socialImage.width)} />
    <meta property="og:image:height" content={String(content.socialImage.height)} />
    <meta property="og:image:alt" content={content.socialImage.alt} />
    <meta name="twitter:card" content="summary_large_image" />
    {props.twitterDomain && <meta name="twitter:domain" content={props.twitterDomain} />}
    {props.twitterUrl && <meta name="twitter:url" content={props.twitterUrl} />}
    <meta name="twitter:title" content={socialTitle} />
    <meta name="twitter:description" content={socialDescription} />
    <meta name="twitter:image" content={props.socialImageUrl} />
    <meta name="twitter:image:alt" content={content.socialImage.alt} />
    <link rel="icon" href="/images/venezuela-flag.svg" type="image/svg+xml" />
    <link rel="alternate icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link
      rel="preload"
      href="/fonts/instrument-sans-latin-400-700.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/archivo-latin-400-900.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/barlow-condensed-latin-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/barlow-condensed-latin-900.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <slot name="head" />
    <ClientRouter fallback="animate" />
    <script
      is:inline
      async
      src={`https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsMeasurementId}`}
    ></script>
    <script is:inline set:html={googleAnalyticsScript}></script>
    <script is:inline type="text/javascript" set:html={microsoftClarityScript}></script>
  </head>
  <body>
    <AnnouncementBar
      ariaLabel={content.announcement.ariaLabel}
      items={content.announcement.items}
    />

    <SiteHeader
      copy={content.header}
      links={headerLinks}
      currentLocale={currentLocale}
      languageOptions={languageOptions}
    />

    <slot />

    <SiteFooter copy={content.footer} />

    <DonationModal
      locale={currentLocale}
      copy={content.donationModal}
      paypalUrl={donation.paypalUrl}
      paypalNotifyUrl={donation.paypalNotifyUrl}
      paypal={donation.paypal}
      amounts={content.donationModal.amounts}
      pagoMovil={donation.pagoMovil}
      binance={donation.binance}
    />
  </body>
</html>
