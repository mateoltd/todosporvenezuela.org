---
import LocalizedTransparencyDayPage from "../../../components/pages/LocalizedTransparencyDayPage.astro";
import { getLocaleContent } from "../../../data/campaign";
import { getLocalizedPath } from "../../../i18n/config";

const { slug } = Astro.params;
const exists = getLocaleContent("en").transparency.days.some(
  (day) => day.slug === slug,
);
const redirectTarget = exists ? null : getLocalizedPath("transparency", "en");

if (redirectTarget) {
  return Astro.redirect(redirectTarget, 302);
}
---

<LocalizedTransparencyDayPage locale="en" slug={slug ?? ""} />
