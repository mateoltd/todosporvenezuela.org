---
import "../styles/global.css";
import DevastationCarousel from "../components/DevastationCarousel.astro";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Preview impacto</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&family=Barlow+Condensed:wght@400;800;900&family=Instrument+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Paper spacer stands in for the bottom of the hero so the section's
         torn top edge can be seen dissolving out of the page. -->
    <div style="height: 120px;"></div>
    <main>
      <DevastationCarousel />
    </main>
  </body>
</html>
