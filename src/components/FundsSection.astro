---
import { Bandage, PackagePlus, Pill, Syringe } from "@lucide/astro";
import styles from "./FundsSection.module.css";

const fundItems = [
  {
    label: "Jeringas e inyectadoras",
    detail: "Para atención directa, curas y aplicación segura.",
    icon: Syringe,
    tone: "yellow"
  },
  {
    label: "Medicamentos",
    detail: "Tratamientos prioritarios según la necesidad reportada.",
    icon: Pill,
    tone: "blue"
  },
  {
    label: "Gasas y guantes",
    detail: "Material básico para higiene, protección y primeros auxilios.",
    icon: Bandage,
    tone: "red"
  },
  {
    label: "Alimentos y otros útiles",
    detail: "Apoyo utilitario cuando la situación local lo requiera.",
    icon: PackagePlus,
    tone: "ink"
  }
];
---

<section class={styles.section} id="ayuda" aria-labelledby="funds-title">
  <div class={styles.heading}>
    <p class={styles.kicker}>Destino de los fondos</p>
    <h2 id="funds-title">La recaudación se transforma en insumos concretos.</h2>
  </div>

  <div class={styles.body}>
    <p>
      Todo el dinero recaudado se utilizará para comprar insumos médicos y
      cubrir necesidades inmediatas que se presenten durante la respuesta.
    </p>

    <div class={styles.grid}>
      {
        fundItems.map((item) => {
          const Icon = item.icon;
          return (
            <article class={`${styles.item} ${styles[item.tone]}`}>
              <span class={styles.icon} aria-hidden="true">
                <Icon size={23} stroke-width={2.2} />
              </span>
              <div>
                <h3>{item.label}</h3>
                <p>{item.detail}</p>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
