---
import { Icon } from "astro-icon/components";
import styles from "./FundsSection.module.css";

const fundItems = [
  {
    label: "Jeringas e inyectadoras",
    detail: "Material esencial para curas, aplicación segura y atención directa.",
    icon: "tabler:vaccine",
    tone: "yellow"
  },
  {
    label: "Medicamentos prioritarios",
    detail: "Tratamientos comprados según necesidades verificadas por el equipo.",
    icon: "tabler:pill",
    tone: "blue"
  },
  {
    label: "Gasas y guantes",
    detail: "Material básico para higiene, protección y primeros auxilios.",
    icon: "tabler:bandage",
    tone: "red"
  },
  {
    label: "Alimentos e hidratación",
    detail: "Apoyo básico para familias que necesitan respuesta inmediata.",
    icon: "tabler:packages",
    tone: "ink"
  }
];
---

<section class={styles.section} id="ayuda" aria-labelledby="funds-title">
  <div class={styles.heading}>
    <p class={styles.kicker}>Destino de los fondos</p>
    <h2 id="funds-title">Tu donación se transforma en ayuda concreta.</h2>
  </div>

  <div class={styles.body}>
    <p>
      Cada aporte se destina a compras y entregas de emergencia: insumos
      médicos, alimentos, hidratación y apoyo básico para familias afectadas por
      el terremoto en Venezuela.
    </p>

    <div class={styles.grid}>
      {
        fundItems.map((item) => {
          return (
            <article class={`${styles.item} ${styles[item.tone]}`}>
              <span class={styles.icon} aria-hidden="true">
                <Icon name={item.icon} size={23} />
              </span>
              <div>
                <h3>{item.label}</h3>
                <p>{item.detail}</p>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
