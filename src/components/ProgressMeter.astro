---
interface Props {
  raised: number;
  goal: number;
}

const { raised, goal } = Astro.props;

const percent = Math.max(0, Math.min(100, Math.round((raised / goal) * 100)));

const currency = (value: number) =>
  new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: "USD",
    maximumFractionDigits: 0
  }).format(value);

const raisedLabel = currency(raised);
const goalLabel = currency(goal);

// Compact axis labels: $200, $500K, $1.5M …
const compact = (value: number) => {
  if (value <= 0) return "0";
  if (value >= 1_000_000) {
    const m = value / 1_000_000;
    return `$${m % 1 ? m.toFixed(1) : m.toFixed(0)}M`;
  }
  if (value >= 1_000) {
    const k = value / 1_000;
    return `$${k % 1 ? k.toFixed(1) : k.toFixed(0)}K`;
  }
  return `$${value}`;
};

// Five evenly spaced ticks (0, ¼, ½, ¾, goal).
const ticks = [0, 0.25, 0.5, 0.75, 1].map((f) => ({
  pos: f * 100,
  label: compact(Math.round(goal * f))
}));

// --- The flag is decorative and fixed; progress is read from the numbers and
// the embedded track. Bands sit in a 0..1000 × 0..130 viewBox, stretched to
// fit. Both seams are slightly diagonal, leaning in opposite directions. ---

// Eight white stars in a shallow arch (the Venezuelan flag), drawn in their own
// aspect-preserving overlay (viewBox 0 0 300 72) so they don't distort.
const starArc = { x0: 28, x1: 272, top: 22, amp: 18, r: 12 };
const starPoints = (cx: number, cy: number, outer: number) => {
  const inner = outer * 0.42;
  const pts: string[] = [];
  for (let i = 0; i < 10; i += 1) {
    const radius = i % 2 === 0 ? outer : inner;
    const angle = (Math.PI / 5) * i - Math.PI / 2;
    pts.push(
      `${(cx + radius * Math.cos(angle)).toFixed(1)},${(cy + radius * Math.sin(angle)).toFixed(1)}`
    );
  }
  return pts.join(" ");
};
const stars = Array.from({ length: 8 }, (_, i) => {
  const t = i / 7;
  const x = starArc.x0 + (starArc.x1 - starArc.x0) * t;
  // Arch (as on the flag): centre rises, ends curve lower (larger y in SVG).
  const y = starArc.top + starArc.amp * (2 * t - 1) ** 2;
  return starPoints(x, y, starArc.r);
});

// Decorative paint flecks scattered just past each seam.
const blueSpecks = [
  { x: 295, y: 34, r: 4 },
  { x: 278, y: 92, r: 3 },
  { x: 288, y: 60, r: 5 },
  { x: 262, y: 48, r: 2.5 },
  { x: 300, y: 104, r: 3.5 }
];
const redSpecks = [
  { x: 636, y: 42, r: 4 },
  { x: 616, y: 88, r: 3 },
  { x: 628, y: 62, r: 5 },
  { x: 604, y: 52, r: 2.5 },
  { x: 642, y: 100, r: 3.5 }
];
---

<div class="meter">
  <div
    class="bar"
    role="progressbar"
    aria-valuenow={percent}
    aria-valuemin={0}
    aria-valuemax={100}
    aria-label={`${raisedLabel} recaudados de ${goalLabel} — ${percent}% de la meta`}
  >
    <svg class="flag" viewBox="0 0 1000 130" preserveAspectRatio="none" aria-hidden="true">
      <defs>
        <filter
          id="m-paint"
          x="-20%"
          y="-40%"
          width="140%"
          height="180%"
          color-interpolation-filters="sRGB"
        >
          <feTurbulence type="turbulence" baseFrequency="0.018 0.13" numOctaves="3" seed="11" result="n1" />
          <feDisplacementMap in="SourceGraphic" in2="n1" scale="32" xChannelSelector="R" yChannelSelector="G" result="d1" />
          <feTurbulence type="fractalNoise" baseFrequency="0.85 0.7" numOctaves="2" seed="4" result="n2" />
          <feDisplacementMap in="d1" in2="n2" scale="6" xChannelSelector="R" yChannelSelector="G" />
        </filter>

        <filter id="m-grain">
          <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="2" stitchTiles="stitch" result="g" />
          <feColorMatrix in="g" type="saturate" values="0" />
        </filter>

        <linearGradient id="m-photo-mask" gradientUnits="userSpaceOnUse" x1="0" y1="0" x2="345" y2="0">
          <stop offset="0" stop-color="#fff" stop-opacity="1" />
          <stop offset="0.6" stop-color="#fff" stop-opacity="0.85" />
          <stop offset="1" stop-color="#fff" stop-opacity="0" />
        </linearGradient>
        <mask id="m-photo">
          <rect x="0" y="0" width="345" height="130" fill="url(#m-photo-mask)" />
        </mask>
      </defs>

      <!-- Yellow band + faintly masked devastation photo -->
      <rect x="-10" y="-5" width="375" height="140" fill="#f6bf00" />
      <image
        href="/images/venezuela-earthquake-aid-distribution.jpg"
        x="0"
        y="0"
        width="360"
        height="130"
        preserveAspectRatio="xMidYMid slice"
        opacity="0.18"
        mask="url(#m-photo)"
        style="mix-blend-mode:multiply"
      />

      <!-- Blue + red bands with brush-painted, diagonally-leaning seams.
           Blue gets more presence and red runs solid to the right edge. -->
      <g filter="url(#m-paint)">
        <polygon points="345,-5 690,-5 740,135 300,135" fill="#0046b8" />
        {blueSpecks.map((s) => <circle cx={s.x} cy={s.y} r={s.r} fill="#0046b8" />)}
        <polygon points="640,-5 1045,-5 1045,135 690,135" fill="#e2122a" />
        {redSpecks.map((s) => <circle cx={s.x} cy={s.y} r={s.r} fill="#e2122a" />)}
      </g>

      <!-- Subtle cloth grain over the coloured area -->
      <rect
        x="-10"
        y="0"
        width="1030"
        height="130"
        fill="#ffffff"
        opacity="0.05"
        filter="url(#m-grain)"
        style="mix-blend-mode:overlay"
      />
    </svg>

    <!-- Stars overlay, kept out of the stretched flag so they stay undistorted -->
    <svg class="stars" viewBox="0 0 300 72" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <g fill="#ffffff" opacity="0.92">
        {stars.map((pts) => <polygon points={pts} />)}
      </g>
    </svg>

    <div class="labels">
      <div class="lbl lbl--raised">
        <strong>{raisedLabel}</strong>
        <span>Recaudado</span>
      </div>
      <div class="lbl lbl--pct">
        <strong>{percent}%</strong>
        <span>De la meta</span>
      </div>
      <div class="lbl lbl--goal">
        <strong>{goalLabel}</strong>
        <span>Meta</span>
      </div>
    </div>

    <!-- Progress track embedded along the bottom of the meter -->
    <div class="progress">
      <span class="progress__fill" style={`width:${percent}%`}></span>
    </div>
  </div>

  <div class="axis" aria-hidden="true">
    {
      ticks.map((tick, i) => (
        <div
          class={`axis__tick${i === 0 ? " axis__tick--first" : ""}${i === ticks.length - 1 ? " axis__tick--last" : ""}`}
          style={`left:${tick.pos}%`}
        >
          <span class="axis__pip" />
          <span class="axis__label">{tick.label}</span>
        </div>
      ))
    }
  </div>
</div>

<style>
  .meter {
    --bar-h: 104px;
    --num-size: clamp(26px, 4vw, 46px);
    --tag-size: clamp(9px, 0.9vw, 12px);
    --rail-inset: 11px;

    position: relative;
    z-index: 3;
  }

  /* ---- The flag is the meter; no surrounding frame ---- */
  .bar {
    position: relative;
    height: var(--bar-h);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: var(--shadow);
  }

  .flag {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Centred over the blue band; width tracks the band so the arch stays on blue */
  .stars {
    position: absolute;
    top: 0;
    left: 50%;
    width: 30%;
    height: 100%;
    transform: translateX(-50%);
    display: block;
    pointer-events: none;
  }

  /* ---- Overlaid figures ---- */
  .labels {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .lbl {
    position: absolute;
    top: 48%;
    display: flex;
    flex-direction: column;
    gap: 4px;
    line-height: 1;
    transform: translateY(-50%);
  }

  .lbl strong {
    font-family: "Archivo", sans-serif;
    font-size: var(--num-size);
    font-weight: 800;
    letter-spacing: -0.01em;
    line-height: 0.9;
  }

  .lbl span {
    font-family: "Archivo", sans-serif;
    font-size: var(--tag-size);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .lbl--raised {
    left: 3.6%;
    color: var(--ink);
  }

  .lbl--raised span {
    color: rgba(16, 24, 32, 0.72);
  }

  .lbl--pct {
    left: 78%;
    transform: translate(-50%, -50%);
    align-items: center;
    text-align: center;
    color: #fff;
  }

  .lbl--pct span {
    color: rgba(255, 255, 255, 0.88);
  }

  /* The goal is a reference target, not a live stat — keep it smaller and
     quieter so it reads as context rather than competing with the % progress. */
  .lbl--goal {
    right: 3.6%;
    align-items: flex-end;
    text-align: right;
    color: rgba(255, 255, 255, 0.9);
  }

  .lbl--goal strong {
    font-size: calc(var(--num-size) * 0.62);
    font-weight: 700;
  }

  .lbl--goal span {
    color: rgba(255, 255, 255, 0.6);
  }

  /* ---- Progress rail coupled to the meter's bottom ---- */
  .progress {
    position: absolute;
    left: var(--rail-inset);
    right: var(--rail-inset);
    bottom: 8px;
    height: 6px;
  }

  .progress__fill {
    display: block;
    height: 100%;
    min-width: 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 1px 3px rgba(16, 24, 32, 0.35);
  }

  /* ---- Scale axis (aligned to the embedded rail) ---- */
  .axis {
    position: relative;
    margin: 11px var(--rail-inset) 0;
    height: 28px;
  }

  .axis__tick {
    position: absolute;
    top: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    transform: translateX(-50%);
  }

  .axis__tick--first {
    transform: translateX(0);
    align-items: flex-start;
  }

  .axis__tick--last {
    transform: translateX(-100%);
    align-items: flex-end;
  }

  .axis__pip {
    width: 1px;
    height: 6px;
    background: rgba(16, 24, 32, 0.28);
  }

  .axis__label {
    font-family: "Archivo", sans-serif;
    font-size: 12px;
    font-weight: 700;
    color: rgba(16, 24, 32, 0.5);
    white-space: nowrap;
  }

  @media (max-width: 900px) {
    .meter {
      --bar-h: 92px;
    }
  }

  @media (max-width: 640px) {
    .meter {
      --bar-h: 78px;
      --num-size: clamp(20px, 6.4vw, 30px);
    }

    /* Too tight for both — keep the live % (which already says "de la meta")
       and let the axis carry the goal figure at its right end. With the goal
       gone, anchor the % to the right edge to mirror Recaudado on the left. */
    .lbl--goal {
      display: none;
    }

    .lbl--pct {
      left: auto;
      right: 3.6%;
      align-items: flex-end;
      text-align: right;
      transform: translateY(-50%);
    }

    .axis__label {
      font-size: 11px;
    }
  }

  @media (max-width: 460px) {
    .lbl--pct span,
    .lbl--goal span,
    .lbl--raised span {
      letter-spacing: 0.12em;
    }

    /* Drop the inner quarter ticks to avoid crowding. */
    .axis__tick:not(.axis__tick--first):not(.axis__tick--last) {
      display: none;
    }
  }
</style>
