---
import { getDonationEnvConfig } from "../lib/donations/config";
import { staticOptimizedImageSrc } from "../data/optimized-images";

interface Props {
  raised: number;
  goal: number;
}

const { raised, goal } = Astro.props;
const meterImageSrc = staticOptimizedImageSrc(
  "venezuela-earthquake-aid-distribution-meter",
  "jpg"
);

const percent = goal > 0 ? Math.max(0, Math.min(100, Math.round((raised / goal) * 100))) : 0;
const pollMs = getDonationEnvConfig().progressPollMs;

const currency = (value: number) =>
  new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: "USD",
    maximumFractionDigits: 0
  }).format(value);

const raisedLabel = currency(raised);
const goalLabel = currency(goal);

// Compact axis labels.
const compact = (value: number) => {
  if (value <= 0) return "0";
  if (value >= 1_000_000) {
    const m = value / 1_000_000;
    return `$${m % 1 ? m.toFixed(1) : m.toFixed(0)}M`;
  }
  if (value >= 1_000) {
    const k = value / 1_000;
    return `$${k % 1 ? k.toFixed(1) : k.toFixed(0)}K`;
  }
  return `$${value}`;
};

const ticks = [0, 0.25, 0.5, 0.75, 1].map((f) => ({
  pos: f * 100,
  label: compact(Math.round(goal * f))
}));

// Stars use a separate viewBox so they do not stretch.
const starArc = { x0: 28, x1: 272, top: 22, amp: 18, r: 12 };
const starPoints = (cx: number, cy: number, outer: number) => {
  const inner = outer * 0.42;
  const pts: string[] = [];
  for (let i = 0; i < 10; i += 1) {
    const radius = i % 2 === 0 ? outer : inner;
    const angle = (Math.PI / 5) * i - Math.PI / 2;
    pts.push(
      `${(cx + radius * Math.cos(angle)).toFixed(1)},${(cy + radius * Math.sin(angle)).toFixed(1)}`
    );
  }
  return pts.join(" ");
};
const stars = Array.from({ length: 8 }, (_, i) => {
  const t = i / 7;
  const x = starArc.x0 + (starArc.x1 - starArc.x0) * t;
  // The arch rises in the center.
  const y = starArc.top + starArc.amp * (2 * t - 1) ** 2;
  return starPoints(x, y, starArc.r);
});

const blueSpecks = [
  { x: 295, y: 34, r: 4 },
  { x: 278, y: 92, r: 3 },
  { x: 288, y: 60, r: 5 },
  { x: 262, y: 48, r: 2.5 },
  { x: 300, y: 104, r: 3.5 }
];
const redSpecks = [
  { x: 636, y: 42, r: 4 },
  { x: 616, y: 88, r: 3 },
  { x: 628, y: 62, r: 5 },
  { x: 604, y: 52, r: 2.5 },
  { x: 642, y: 100, r: 3.5 }
];
---

<div
  class="meter"
  data-donation-meter
  data-progress-events-url="/api/donations/events"
  data-progress-url="/api/donations/progress"
  data-poll-ms={Number.isFinite(pollMs) ? pollMs : 15000}
>
  <div
    class="bar"
    data-progress-bar
    role="progressbar"
    aria-valuenow={percent}
    aria-valuemin={0}
    aria-valuemax={100}
    aria-label={`${raisedLabel} recaudados de ${goalLabel}, ${percent}% de la meta`}
  >
    <svg class="flag" viewBox="0 0 1000 130" preserveAspectRatio="none" aria-hidden="true">
      <defs>
        <filter
          id="m-paint"
          x="-20%"
          y="-40%"
          width="140%"
          height="180%"
          color-interpolation-filters="sRGB"
        >
          <feTurbulence type="turbulence" baseFrequency="0.018 0.13" numOctaves="3" seed="11" result="n1" />
          <feDisplacementMap in="SourceGraphic" in2="n1" scale="32" xChannelSelector="R" yChannelSelector="G" result="d1" />
          <feTurbulence type="fractalNoise" baseFrequency="0.85 0.7" numOctaves="2" seed="4" result="n2" />
          <feDisplacementMap in="d1" in2="n2" scale="6" xChannelSelector="R" yChannelSelector="G" />
        </filter>

        <filter id="m-grain">
          <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="2" stitchTiles="stitch" result="g" />
          <feColorMatrix in="g" type="saturate" values="0" />
        </filter>

        <linearGradient id="m-photo-mask" gradientUnits="userSpaceOnUse" x1="0" y1="0" x2="345" y2="0">
          <stop offset="0" stop-color="#fff" stop-opacity="1" />
          <stop offset="0.6" stop-color="#fff" stop-opacity="0.85" />
          <stop offset="1" stop-color="#fff" stop-opacity="0" />
        </linearGradient>
        <mask id="m-photo">
          <rect x="0" y="0" width="345" height="130" fill="url(#m-photo-mask)" />
        </mask>
      </defs>

      <rect x="-10" y="-5" width="375" height="140" fill="#f6bf00" />
      <image
        href={meterImageSrc}
        x="0"
        y="0"
        width="360"
        height="130"
        preserveAspectRatio="xMidYMid slice"
        opacity="0.18"
        mask="url(#m-photo)"
        style="mix-blend-mode:multiply"
      />

      <g filter="url(#m-paint)">
        <polygon points="345,-5 690,-5 740,135 300,135" fill="#0046b8" />
        {blueSpecks.map((s) => <circle cx={s.x} cy={s.y} r={s.r} fill="#0046b8" />)}
        <polygon points="640,-5 1045,-5 1045,135 690,135" fill="#e2122a" />
        {redSpecks.map((s) => <circle cx={s.x} cy={s.y} r={s.r} fill="#e2122a" />)}
      </g>

      <rect
        x="-10"
        y="0"
        width="1030"
        height="130"
        fill="#ffffff"
        opacity="0.05"
        filter="url(#m-grain)"
        style="mix-blend-mode:overlay"
      />
    </svg>

    <svg class="stars" viewBox="0 0 300 72" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <g fill="#ffffff" opacity="0.92">
        {stars.map((pts) => <polygon points={pts} />)}
      </g>
    </svg>

    <div class="labels">
      <div class="lbl lbl--raised">
        <strong data-raised-label>{raisedLabel}</strong>
        <span>Recaudado</span>
      </div>
      <div class="lbl lbl--pct">
        <strong data-percent-label>{percent}%</strong>
        <span>De la meta</span>
      </div>
      <div class="lbl lbl--goal">
        <strong data-goal-label>{goalLabel}</strong>
        <span>Meta</span>
      </div>
    </div>

    <div class="progress">
      <span class="progress__fill" data-progress-fill style={`width:${percent}%`}></span>
    </div>
  </div>

  <div class="axis" aria-hidden="true">
    {
      ticks.map((tick, i) => (
        <div
          class={`axis__tick${i === 0 ? " axis__tick--first" : ""}${i === ticks.length - 1 ? " axis__tick--last" : ""}`}
          style={`left:${tick.pos}%`}
        >
          <span class="axis__pip" />
          <span class="axis__label">{tick.label}</span>
        </div>
      ))
    }
  </div>
</div>

<script>
  type DonationProgress = {
    currency: string;
    goal: number;
    goalCents?: number;
    percent: number;
    raised: number;
    raisedCents?: number;
    updatedAt?: string | null;
  };

  const donationMeters = Array.from(
    document.querySelectorAll<HTMLElement>("[data-donation-meter]")
  );

  const formatDonationCurrency = (value: number, currency: string) =>
    new Intl.NumberFormat("en-US", {
      style: "currency",
      currency,
      maximumFractionDigits: Number.isInteger(value) ? 0 : 2
    }).format(value);

  const applyDonationProgress = (meter: HTMLElement, progress: DonationProgress) => {
    const bar = meter.querySelector<HTMLElement>("[data-progress-bar]");
    const fill = meter.querySelector<HTMLElement>("[data-progress-fill]");
    const raisedLabel = meter.querySelector<HTMLElement>("[data-raised-label]");
    const percentLabel = meter.querySelector<HTMLElement>("[data-percent-label]");
    const goalLabel = meter.querySelector<HTMLElement>("[data-goal-label]");
    const percent = Math.max(0, Math.min(100, Math.round(progress.percent)));
    const raised = formatDonationCurrency(progress.raised, progress.currency);
    const goal = formatDonationCurrency(progress.goal, progress.currency);

    if (bar) {
      bar.setAttribute("aria-valuenow", String(percent));
      bar.setAttribute("aria-label", `${raised} recaudados de ${goal}, ${percent}% de la meta`);
    }
    if (fill) fill.style.width = `${percent}%`;
    if (raisedLabel) raisedLabel.textContent = raised;
    if (percentLabel) percentLabel.textContent = `${percent}%`;
    if (goalLabel) goalLabel.textContent = goal;
  };

  const refreshDonationProgress = async (meter: HTMLElement) => {
    const progressUrl = meter.getAttribute("data-progress-url") || "/api/donations/progress";
    const url = new URL(progressUrl, window.location.href);
    url.searchParams.set("_", String(Date.now()));

    const response = await fetch(url, {
      cache: "no-store",
      headers: {
        "Cache-Control": "no-cache"
      }
    });
    if (!response.ok) throw new Error("Donation progress fetch failed");

    const progress = (await response.json()) as DonationProgress;
    applyDonationProgress(meter, progress);
  };

  const connectDonationProgressStream = () => {
    if (!donationMeters.length || !("EventSource" in window)) return;

    const eventsUrl =
      donationMeters[0]?.getAttribute("data-progress-events-url") || "/api/donations/events";
    const url = new URL(eventsUrl, window.location.href);
    url.searchParams.set("_", String(Date.now()));

    const events = new EventSource(url);

    events.addEventListener("progress", (event) => {
      try {
        const progress = JSON.parse((event as MessageEvent).data) as DonationProgress;
        donationMeters.forEach((meter) => applyDonationProgress(meter, progress));
      } catch {
        // Ignore malformed stream events and let the polling fallback continue.
      }
    });

    events.addEventListener("error", () => {
      donationMeters.forEach((meter) => {
        void refreshDonationProgress(meter).catch(() => undefined);
      });
    });
  };

  donationMeters.forEach((meter) => {
    void refreshDonationProgress(meter).catch(() => undefined);

    const pollMs = Number(meter.getAttribute("data-poll-ms"));
    if (Number.isFinite(pollMs) && pollMs > 0) {
      window.setInterval(() => {
        void refreshDonationProgress(meter).catch(() => undefined);
      }, pollMs);
    }
  });

  connectDonationProgressStream();

  window.addEventListener("donation:paypal-complete", () => {
    donationMeters.forEach((meter) => {
      [0, 2000, 6000, 15000].forEach((delay) => {
        window.setTimeout(() => {
          void refreshDonationProgress(meter).catch(() => undefined);
        }, delay);
      });
    });
  });

  window.addEventListener("pageshow", () => {
    donationMeters.forEach((meter) => {
      void refreshDonationProgress(meter).catch(() => undefined);
    });
  });

  document.addEventListener("visibilitychange", () => {
    if (document.visibilityState !== "visible") return;

    donationMeters.forEach((meter) => {
      void refreshDonationProgress(meter).catch(() => undefined);
    });
  });
</script>

<style>
  .meter {
    --bar-h: 104px;
    --num-size: clamp(26px, 4vw, 46px);
    --tag-size: clamp(9px, 0.9vw, 12px);
    --rail-inset: 11px;

    position: relative;
    z-index: 3;
  }

  .bar {
    position: relative;
    height: var(--bar-h);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: var(--shadow);
  }

  .flag {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Keep the arch centered over the blue band. */
  .stars {
    position: absolute;
    top: 0;
    left: 50%;
    width: 30%;
    height: 100%;
    transform: translateX(-50%);
    display: block;
    pointer-events: none;
  }

  .labels {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .lbl {
    position: absolute;
    top: 48%;
    display: flex;
    flex-direction: column;
    gap: 4px;
    line-height: 1;
    transform: translateY(-50%);
  }

  .lbl strong {
    font-family: "Archivo", sans-serif;
    font-size: var(--num-size);
    font-weight: 800;
    letter-spacing: -0.01em;
    line-height: 0.9;
  }

  .lbl span {
    font-family: "Archivo", sans-serif;
    font-size: var(--tag-size);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .lbl--raised {
    left: 3.6%;
    color: var(--ink);
  }

  .lbl--raised span {
    color: rgba(16, 24, 32, 0.72);
  }

  .lbl--pct {
    left: 78%;
    transform: translate(-50%, -50%);
    align-items: center;
    text-align: center;
    color: #fff;
  }

  .lbl--pct span {
    color: rgba(255, 255, 255, 0.88);
  }

  /* Goal is context, so it stays quieter than live progress. */
  .lbl--goal {
    right: 3.6%;
    align-items: flex-end;
    text-align: right;
    color: rgba(255, 255, 255, 0.9);
  }

  .lbl--goal strong {
    font-size: calc(var(--num-size) * 0.62);
    font-weight: 700;
  }

  .lbl--goal span {
    color: rgba(255, 255, 255, 0.6);
  }

  .progress {
    position: absolute;
    left: var(--rail-inset);
    right: var(--rail-inset);
    bottom: 8px;
    height: 6px;
  }

  .progress__fill {
    display: block;
    height: 100%;
    min-width: 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 1px 3px rgba(16, 24, 32, 0.35);
  }

  .axis {
    position: relative;
    margin: 11px var(--rail-inset) 0;
    height: 28px;
  }

  .axis__tick {
    position: absolute;
    top: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    transform: translateX(-50%);
  }

  .axis__tick--first {
    transform: translateX(0);
    align-items: flex-start;
  }

  .axis__tick--last {
    transform: translateX(-100%);
    align-items: flex-end;
  }

  .axis__pip {
    width: 1px;
    height: 6px;
    background: rgba(16, 24, 32, 0.28);
  }

  .axis__label {
    font-family: "Archivo", sans-serif;
    font-size: 12px;
    font-weight: 700;
    color: rgba(16, 24, 32, 0.5);
    white-space: nowrap;
  }

  @media (max-width: 900px) {
    .meter {
      --bar-h: 92px;
    }
  }

  @media (max-width: 640px) {
    .meter {
      --bar-h: 78px;
      --num-size: clamp(20px, 6.4vw, 30px);
    }

    /* On narrow screens, the axis carries the goal value. */
    .lbl--goal {
      display: none;
    }

    .lbl--pct {
      left: auto;
      right: 3.6%;
      align-items: flex-end;
      text-align: right;
      transform: translateY(-50%);
    }

    .axis__label {
      font-size: 11px;
    }
  }

  @media (max-width: 460px) {
    .lbl--pct span,
    .lbl--goal span,
    .lbl--raised span {
      letter-spacing: 0.12em;
    }

    /* Hide inner ticks to avoid crowding. */
    .axis__tick:not(.axis__tick--first):not(.axis__tick--last) {
      display: none;
    }
  }
</style>
