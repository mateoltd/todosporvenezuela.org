---
interface Props {
  raised: number;
  goal: number;
}

const { raised, goal } = Astro.props;

const percent = Math.max(0, Math.min(100, Math.round((raised / goal) * 100)));
const remaining = Math.max(0, goal - raised);

const currency = (value: number) =>
  new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: "USD",
    maximumFractionDigits: 0
  }).format(value);

const raisedLabel = currency(raised);
const goalLabel = currency(goal);
const remainingLabel = currency(remaining);

// The flag IS the progress. Yellow = Recaudado and grows with the %, while
// blue and red shrink as funding arrives — but each keeps a floor so the
// flag is never obliterated (at 100% it settles near 82 / 10 / 8).
const minBlue = 10;
const minRed = 8;
const yellowMax = 100 - minBlue - minRed;
const yellowW = Math.min(percent, yellowMax);
const rest = 100 - yellowW;
const blueW = (rest * minBlue) / (minBlue + minRed);
const redW = (rest * minRed) / (minBlue + minRed);

// Band seams in the 0..1000 viewBox.
const s1 = yellowW * 10;
const s2 = (yellowW + blueW) * 10;

// Stars scattered across the (dynamic) blue band; soft and tone-on-tone, with
// a few near the seams so they get partly torn off.
const starSpec = [
  { fx: 0.14, y: 82, s: 28, o: 0.5 },
  { fx: 0.27, y: 46, s: 24, o: 0.4 },
  { fx: 0.4, y: 84, s: 34, o: 0.55 },
  { fx: 0.52, y: 44, s: 26, o: 0.45 },
  { fx: 0.64, y: 82, s: 30, o: 0.5 },
  { fx: 0.77, y: 50, s: 36, o: 0.52 },
  { fx: 0.9, y: 80, s: 24, o: 0.4 }
];
const stars = starSpec.map((d) => ({
  x: +(s1 + d.fx * (s2 - s1)).toFixed(1),
  y: d.y,
  s: d.s,
  o: d.o
}));

const segments = [
  {
    mod: "raised",
    label: "Recaudado",
    value: raisedLabel,
    detail: `${percent}% de la meta alcanzada`,
    left: 0,
    width: yellowW
  },
  {
    mod: "gap",
    label: "Por recaudar",
    value: remainingLabel,
    detail: `Faltan para llegar a la meta de ${goalLabel}`,
    left: yellowW,
    width: blueW
  },
  {
    mod: "urgency",
    label: "Emergencia activa",
    value: "M7.5",
    detail: "Sismo cerca de Yumare · respuesta inmediata en curso",
    left: yellowW + blueW,
    width: redW
  }
];
---

<div class="meter">
  <div class="meter__head">
    <div class="meter__stat meter__stat--raised">
      <span class="meter__eyebrow">Recaudado</span>
      <strong class="meter__amount">{raisedLabel}</strong>
    </div>

    <div class="meter__stat meter__stat--percent">
      <strong class="meter__big">{percent}%</strong>
      <span class="meter__eyebrow">De la meta</span>
    </div>

    <div class="meter__stat meter__stat--goal">
      <span class="meter__eyebrow">Meta</span>
      <strong class="meter__amount meter__amount--muted">{goalLabel}</strong>
    </div>
  </div>

  <div
    class="bar"
    role="progressbar"
    aria-valuenow={percent}
    aria-valuemin={0}
    aria-valuemax={100}
    aria-label={`${percent}% de la meta recaudado`}
  >
    <svg class="bar__flag" viewBox="0 0 1000 120" preserveAspectRatio="none" aria-hidden="true">
      <defs>
        <filter id="m-seams" x="-6%" y="-60%" width="112%" height="220%" color-interpolation-filters="sRGB">
          <feTurbulence type="fractalNoise" baseFrequency="0.009 0.05" numOctaves="4" seed="6" result="n" />
          <feDisplacementMap in="SourceGraphic" in2="n" scale="22" xChannelSelector="R" yChannelSelector="G" />
        </filter>
        <filter id="m-grain">
          <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="2" stitchTiles="stitch" result="g" />
          <feColorMatrix in="g" type="saturate" values="0" />
        </filter>
        <symbol id="m-star" viewBox="0 0 24 24">
          <path d="M12 1.6l3.09 6.26 6.91 1-5 4.87 1.18 6.88L12 17.35l-6.18 3.25L7 13.73l-5-4.87 6.91-1z" />
        </symbol>
      </defs>

      <g filter="url(#m-seams)">
        <rect x="-80" y="-40" width={s1 + 120} height="200" fill="#f6bf00" />
        <rect x={s1 - 40} y="-40" width={s2 - s1 + 80} height="200" fill="#0046b8" />
        <rect x={s2 - 40} y="-40" width={1120 - s2} height="200" fill="#e2122a" />
      </g>

      <g>
        {
          stars.map((star) => (
            <use
              href="#m-star"
              x={star.x - star.s / 2}
              y={star.y - star.s / 2}
              width={star.s}
              height={star.s}
              fill="#ffffff"
              opacity={star.o}
            />
          ))
        }
      </g>

      <rect
        x="-40"
        y="0"
        width="1080"
        height="120"
        fill="#ffffff"
        opacity="0.07"
        filter="url(#m-grain)"
        style="mix-blend-mode:overlay"
      />
    </svg>

    <div class="bar__zones">
      {
        segments.map((segment) => (
          <button
            type="button"
            class={`zone zone--${segment.mod}`}
            style={`left:${segment.left}%;width:${segment.width}%`}
            aria-label={`${segment.label}: ${segment.value}. ${segment.detail}`}
          >
            <span class="tip">
              <span class="tip__label">{segment.label}</span>
              <span class="tip__value">{segment.value}</span>
              <span class="tip__detail">{segment.detail}</span>
            </span>
          </button>
        ))
      }
    </div>
  </div>
</div>

<style>
  .meter {
    --meter-head-gap: 16px;
    --meter-amount-size: 40px;
    --meter-percent-size: 64px;
    --meter-bar-height: 88px;

    position: relative;
    z-index: 3;
  }

  /* ---- Stat header ---- */
  .meter__head {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: end;
    gap: 14px 24px;
    margin-bottom: var(--meter-head-gap);
  }

  .meter__stat {
    display: flex;
    flex-direction: column;
    gap: 7px;
    min-width: 0;
  }

  .meter__stat--raised {
    justify-self: start;
    text-align: left;
  }

  .meter__stat--percent {
    justify-self: center;
    align-items: center;
    gap: 4px;
    text-align: center;
  }

  .meter__stat--goal {
    justify-self: end;
    text-align: right;
  }

  .meter__eyebrow {
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .meter__amount {
    font-family: "Archivo", sans-serif;
    font-size: var(--meter-amount-size);
    font-weight: 800;
    line-height: 0.92;
    color: var(--ink);
  }

  .meter__amount--muted {
    color: rgba(16, 24, 32, 0.42);
  }

  .meter__big {
    font-family: "Archivo", sans-serif;
    font-size: var(--meter-percent-size);
    font-weight: 900;
    line-height: 1;
    letter-spacing: 0;
    color: var(--ink);
  }

  .meter__stat--percent .meter__eyebrow {
    color: var(--red);
  }

  /* ---- The flag bar ---- */
  .bar {
    position: relative;
    height: var(--meter-bar-height);
    overflow: visible;
    border-radius: var(--radius);
    background: #e7e3da;
    box-shadow: var(--shadow);
  }

  .bar__flag {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: var(--radius);
    filter: drop-shadow(0 1px 0 rgba(255, 255, 255, 0.25));
  }

  /* ---- Hoverable meaning zones ---- */
  .bar__zones {
    position: absolute;
    inset: 0;
    z-index: 2;
  }

  .zone {
    position: absolute;
    top: 0;
    bottom: 0;
    margin: 0;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
    appearance: none;
    -webkit-appearance: none;
  }

  .zone::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0);
    transition: background 0.15s ease;
  }

  .zone:hover::before,
  .zone:focus-visible::before {
    background: rgba(255, 255, 255, 0.14);
  }

  .zone:focus-visible {
    outline: none;
  }

  /* ---- Tooltip ---- */
  .tip {
    position: absolute;
    bottom: calc(100% + 14px);
    left: 50%;
    z-index: 4;
    display: flex;
    flex-direction: column;
    gap: 3px;
    width: max-content;
    max-width: 250px;
    padding: 12px 16px;
    border-radius: 12px;
    background: var(--ink);
    box-shadow: 0 18px 40px rgba(16, 24, 32, 0.28);
    text-align: left;
    opacity: 0;
    visibility: hidden;
    transform: translate(-50%, 6px);
    transition: opacity 0.16s ease, transform 0.16s ease;
    pointer-events: none;
  }

  .tip::after {
    content: "";
    position: absolute;
    top: 100%;
    left: 50%;
    width: 12px;
    height: 12px;
    margin: -6px 0 0 -6px;
    background: var(--ink);
    border-radius: 2px;
    transform: rotate(45deg);
  }

  .zone:hover .tip,
  .zone:focus-visible .tip,
  .zone:focus .tip {
    opacity: 1;
    visibility: visible;
    transform: translate(-50%, 0);
  }

  /* Keep edge tooltips on screen. */
  .zone--raised .tip {
    left: 0;
    transform: translate(0, 6px);
  }

  .zone--raised:hover .tip,
  .zone--raised:focus-visible .tip,
  .zone--raised:focus .tip {
    transform: translate(0, 0);
  }

  .zone--raised .tip::after {
    left: 28px;
  }

  .zone--urgency .tip {
    left: auto;
    right: 0;
    transform: translate(0, 6px);
  }

  .zone--urgency:hover .tip,
  .zone--urgency:focus-visible .tip,
  .zone--urgency:focus .tip {
    transform: translate(0, 0);
  }

  .zone--urgency .tip::after {
    left: auto;
    right: 22px;
  }

  .tip__label {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
  }

  .tip__value {
    font-family: "Archivo", sans-serif;
    font-size: 24px;
    font-weight: 800;
    line-height: 1;
    color: #fff;
  }

  .zone--raised .tip__value {
    color: var(--yellow);
  }

  .zone--urgency .tip__value {
    color: #ff5a6a;
  }

  .tip__detail {
    margin-top: 2px;
    font-size: 13px;
    line-height: 1.35;
    color: rgba(255, 255, 255, 0.82);
  }

  @media (max-width: 900px) {
    .meter__amount {
      font-size: 34px;
    }

    .meter__big {
      font-size: 56px;
    }

    .bar {
      height: 84px;
    }
  }

  @media (max-width: 640px) {
    .meter__head {
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-bottom: 16px;
    }

    .meter__stat--percent {
      grid-row: 1;
      grid-column: 1 / -1;
    }

    .meter__stat--raised {
      grid-row: 2;
      grid-column: 1;
    }

    .meter__stat--goal {
      grid-row: 2;
      grid-column: 2;
    }

    .meter__big {
      font-size: 64px;
    }

    .meter__amount {
      font-size: 30px;
    }

    .bar {
      height: 72px;
    }

    .tip {
      max-width: 200px;
    }
  }

  @media (max-width: 380px) {
    .meter__amount {
      font-size: 26px;
    }

    .meter__big {
      font-size: 54px;
    }
  }
</style>
