---
import { Icon } from "astro-icon/components";
import { getLocaleContent, type CampaignContent } from "../data/campaign";
import styles from "./TransparencySection.module.css";

interface Props {
  copy?: CampaignContent["transparency"];
  dayBasePath?: string;
  links?: {
    home: string;
    faq: string;
  };
}

const {
  copy = getLocaleContent().transparency,
  dayBasePath = "/es/transparencia",
  links = { home: "/es/", faq: "/es/#faq" },
} = Astro.props;

const doneDays = copy.days;
const activeDayNumber = doneDays.length + 1;
const hasActiveDay = activeDayNumber <= copy.totalDays;
const futureDays: number[] = [];
for (let day = activeDayNumber + 1; day <= copy.totalDays; day += 1) {
  futureDays.push(day);
}

---

<section class={styles.section} aria-labelledby="transparencia-title">
  <div class={styles.wrap}>
    <header class={styles.head}>
      <p class={styles.eyebrow}>{copy.eyebrow}</p>
      <h1 id="transparencia-title" class={styles.display}>{copy.heading}</h1>
      <p class={styles.lede}>{copy.lede}</p>
    </header>

    <div class={styles.feed}>
      <ol class={styles.timeline}>
        {
          doneDays.map((day) => (
            <li class={styles.entry} data-state="done">
              <a class={styles.entryLink} href={`${dayBasePath}/${day.slug}`}>
                <span class={styles.node} aria-hidden="true" />
                <span class={styles.entryContent}>
                  <span class={styles.day}>{day.dateShort}</span>
                  <span class={styles.entryTitle}>{day.title}</span>
                </span>
                <span class={styles.entryAction}>
                  <span class={styles.entryActionLabel}>{copy.viewReportLabel}</span>
                  <Icon name="tabler:arrow-right" size={18} aria-hidden="true" />
                </span>
              </a>
            </li>
          ))
        }

        {
          hasActiveDay && (
            <li class={styles.entry} data-state="active">
              <div class={styles.entryLink} aria-disabled="true">
                <span class={styles.node} aria-hidden="true" />
                <span class={styles.entryContent}>
                  <span class={styles.day}>{copy.currentDateShort}</span>
                  <span class={styles.entryTitle}>{copy.currentLabel}</span>
                </span>
                <span class={styles.entryAction}>
                  <span class={styles.entryActionLabel}>
                    {copy.viewReportLabel}
                  </span>
                  <Icon name="tabler:arrow-right" size={18} aria-hidden="true" />
                </span>
              </div>
            </li>
          )
        }

        {
          futureDays.map(() => (
            <li class={styles.entry} data-state="future" aria-hidden="true">
              <span class={styles.node} />
            </li>
          ))
        }
      </ol>
    </div>

    <footer class={styles.closing}>
      <p>{copy.closing}</p>
      <div class={styles.closingLinks}>
        <a href={links.faq} class={styles.linkPrimary}>
          {copy.faqLink}
          <Icon name="tabler:arrow-right" size={18} aria-hidden="true" />
        </a>
        <a href={links.home} class={styles.linkGhost}>{copy.homeLink}</a>
      </div>
    </footer>
  </div>
</section>
