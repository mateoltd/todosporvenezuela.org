---
import { Icon } from "astro-icon/components";
import { getLocaleContent, type DonationModalCopy } from "../data/campaign";

interface Method {
  id: string;
  name: string;
  icon: string;
  marks?: string[];
  desc: string;
  lead: string;
  fields: { label: string; value: string }[];
  steps: string[];
  conversion?: "bcv-ves";
  action: "paypal" | "confirm";
  actionLabel: string;
}

interface Props {
  method: Method;
  paypalUrl?: string;
  copy?: DonationModalCopy["methodItem"];
}

const {
  method,
  paypalUrl = "https://www.paypal.com/donate",
  copy = getLocaleContent().donationModal.methodItem,
} = Astro.props;
---

<div class="dm__method" data-method-item={method.id}>
  <button
    type="button"
    class="dm__method-head"
    data-method-toggle={method.id}
    aria-expanded="false"
  >
    <span class="dm__method-icon">
      <Icon name={method.icon} size={22} />
    </span>
    <span class="dm__method-text">
      <strong>{method.name}</strong>
      <span>{method.desc}</span>
      {
        method.marks && method.marks.length > 0 && (
          <span class="dm__method-marks" aria-hidden="true">
            {method.marks.map((mark) => (
              <Icon class="dm__method-mark" name={mark} size={26} />
            ))}
          </span>
        )
      }
    </span>
    <Icon class="dm__method-chevron" name="tabler:chevron-down" size={20} />
  </button>

  <div class="dm__method-body">
    <p class="dm__instr-lead">{method.lead}</p>

    {
      method.conversion === "bcv-ves" && (
        <div class="dm__conversion" data-ves-conversion data-rate-endpoint="/api/bcv-usd">
          <span class="dm__field-label">{copy.vesAmountLabel}</span>
          <button
            type="button"
            class="dm__field-copy dm__conversion-copy"
            data-copy=""
            data-ves-copy
            aria-label={copy.copyVesAmountLabel}
            disabled
          >
            <span class="dm__field-value dm__conversion-value" data-ves-amount>
              {copy.calculatingLabel}
            </span>
            <span class="dm__copy-icon">
              <Icon name="tabler:copy" size={17} />
            </span>
            <span class="dm__check-icon">
              <Icon name="tabler:check" size={17} />
            </span>
          </button>
          <span class="dm__conversion-meta" data-ves-rate aria-live="polite">
            {copy.queryingRateLabel}
          </span>
        </div>
      )
    }

    {
      method.fields.length > 0 && (
        <div class="dm__fields">
          {method.fields.map((field) => (
            <div class="dm__field">
              <span class="dm__field-label">{field.label}</span>
              {field.value ? (
                <button
                  type="button"
                  class="dm__field-copy"
                  data-copy={field.value}
                  aria-label={copy.copyFieldLabel.replace("{field}", field.label)}
                >
                  <span class="dm__field-value">{field.value}</span>
                  <span class="dm__copy-icon">
                    <Icon name="tabler:copy" size={17} />
                  </span>
                  <span class="dm__check-icon">
                    <Icon name="tabler:check" size={17} />
                  </span>
                </button>
              ) : (
                <span class="dm__field-pending">{copy.pendingLabel}</span>
              )}
            </div>
          ))}
        </div>
      )
    }

    <ol class="dm__steps">
      {method.steps.map((step) => <li>{step}</li>)}
    </ol>

    {
      method.action === "paypal" ? (
        <div class="dm__paypal-shell">
          <a
            class="dm__cta dm__paypal-link"
            href={paypalUrl}
            target="_blank"
            rel="noopener"
            data-paypal-link
          >
            {method.actionLabel}
            <Icon name="tabler:external-link" size={19} />
          </a>
        </div>
      ) : (
        <button class="dm__cta" type="button" data-done>
          {method.actionLabel}
          <Icon name="tabler:check" size={19} />
        </button>
      )
    }
  </div>
</div>
