---
import { Icon } from "astro-icon/components";
import styles from "./FaqSection.module.css";

const faqs = [
  {
    question: "¿Qué se compra con mi donación?",
    answer:
      "Insumos médicos, alimentación, hidratación y apoyo básico para personas necesitadas tras el terremoto, incluyendo familias en zonas remotas del país."
  },
  {
    question: "¿Quiénes están detrás de la campaña?",
    answer:
      "Somos un grupo de jóvenes cristianos venezolanos que vive en el país y tomó la iniciativa de ayudar ante el sufrimiento que está viendo de cerca. Valentina Muriel, Cristal Navas, Abraham Barrios y Marlon Amarista coordinan la campaña.",
    link: {
      href: "https://www.instagram.com/p/DaD7tL_vjyc/",
      label: "Ver el video de presentación del proyecto"
    }
  },
  {
    question: "¿Cómo sé que es confiable?",
    answer:
      "Los organizadores son miembros reconocidos de sus comunidades y tienen responsabilidades en ministerios e iglesias locales. Esa referencia comunitaria ayuda a dar confianza, sin convertir esta campaña en una colecta institucional."
  },
  {
    question: "¿Cómo dono desde el exterior?",
    answer:
      "Si estás fuera de Venezuela, puedes donar con PayPal usando tarjeta o cuenta PayPal, o enviar USDT por Binance Pay desde cualquier país donde tengas acceso a esos servicios."
  },
  {
    question: "¿Cómo dono desde Venezuela?",
    answer:
      "Si estás en Venezuela, puedes aportar con Pago Móvil en bolívares. También puedes usar Binance Pay si prefieres donar en USDT."
  },
  {
    question: "¿Publicarán reportes?",
    answer:
      "Sí. Publicaremos reportes transparentes todos los días con el avance de la recaudación, el uso de los fondos y las entregas realizadas conforme avance la respuesta."
  },
  {
    question: "¿Y si no puedo donar dinero?",
    answer:
      "También puedes ayudar orando, compartiendo la campaña y enviándola a más personas. Cada gesto ayuda a que la ayuda llegue más lejos."
  },
  {
    question: "¿Cómo confirmo Binance Pay o Pago Móvil?",
    answer:
      "Conserva tu comprobante y pulsa Ya hice mi pago en el modal para cerrar el flujo de confirmación. Si el equipo necesita validar algún dato, usará la información del comprobante."
  },
  {
    question: "¿Hay un monto mínimo?",
    answer:
      "Puedes elegir uno de los montos sugeridos o escribir otro monto desde 1 dólar. Cada aporte suma para cubrir necesidades urgentes."
  }
];
---

<section class={styles.faqBand} id="faq" aria-labelledby="faq-title" data-faq-root>
  <div class={styles.inner}>
    <div class={styles.heading}>
      <p class={styles.eyebrow}>Dona con confianza</p>
      <h2 id="faq-title">
        <span>Preguntas</span>
        <strong>frecuentes</strong>
      </h2>
    </div>

    <div class={styles.list}>
      {
        faqs.map((faq, index) => (
          <article class={styles.item} data-faq-item>
            <button
              class={styles.summary}
              type="button"
              aria-expanded="false"
              aria-controls={`faq-answer-${index}`}
              data-faq-trigger
            >
              <span class={styles.index} aria-hidden="true">
                {String(index + 1).padStart(2, "0")}
              </span>
              <span class={styles.question}>{faq.question}</span>
              <span class={styles.toggleIcon} aria-hidden="true">
                <Icon name="tabler:plus" size={24} />
              </span>
            </button>
            <div
              class={styles.answer}
              id={`faq-answer-${index}`}
              data-faq-panel
              hidden
            >
              <div class={styles.answerInner}>
                <p>{faq.answer}</p>
                {"link" in faq && faq.link && (
                  <a href={faq.link.href} target="_blank" rel="noreferrer">
                    {faq.link.label}
                  </a>
                )}
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <div class={styles.action}>
      <button class={styles.donateCta} type="button" data-donate-open>
        <Icon name="tabler:heart-filled" size={22} aria-hidden="true" />
        <span>Donar ahora</span>
      </button>
    </div>
  </div>
</section>

<script>
  const faqRoots = document.querySelectorAll<HTMLElement>("[data-faq-root]");

  faqRoots.forEach((root) => {
    if (root.dataset.faqReady === "true") return;
    root.dataset.faqReady = "true";

    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

    root.querySelectorAll<HTMLElement>("[data-faq-item]").forEach((item) => {
      const trigger = item.querySelector<HTMLButtonElement>("[data-faq-trigger]");
      const panel = item.querySelector<HTMLElement>("[data-faq-panel]");

      if (!trigger || !panel) return;

      const setPanelHeight = (height: number | "auto") => {
        panel.style.height = height === "auto" ? "auto" : `${height}px`;
      };

      const openPanel = () => {
        trigger.setAttribute("aria-expanded", "true");
        item.dataset.open = "true";
        panel.hidden = false;
        panel.dataset.open = "true";

        if (reduceMotion.matches) {
          setPanelHeight("auto");
          return;
        }

        setPanelHeight(0);
        window.requestAnimationFrame(() => {
          setPanelHeight(panel.scrollHeight);
        });
      };

      const closePanel = () => {
        trigger.setAttribute("aria-expanded", "false");
        delete item.dataset.open;
        delete panel.dataset.open;

        if (reduceMotion.matches) {
          panel.hidden = true;
          panel.style.height = "";
          return;
        }

        setPanelHeight(panel.getBoundingClientRect().height);
        window.requestAnimationFrame(() => {
          setPanelHeight(0);
        });
      };

      panel.addEventListener("transitionend", (event) => {
        if (event.target !== panel || event.propertyName !== "height") return;

        if (trigger.getAttribute("aria-expanded") === "true") {
          setPanelHeight("auto");
        } else {
          panel.hidden = true;
          panel.style.height = "";
        }
      });

      trigger.addEventListener("click", () => {
        if (trigger.getAttribute("aria-expanded") === "true") {
          closePanel();
        } else {
          openPanel();
        }
      });
    });
  });
</script>
