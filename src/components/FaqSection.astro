---
import { Icon } from "astro-icon/components";
import {
  buildFaqs,
  getLocaleContent,
  type CampaignContent,
  type CampaignFaq,
} from "../data/campaign";
import DonateButton from "./DonateButton.astro";
import styles from "./FaqSection.module.css";

interface Props {
  faqs?: CampaignFaq[];
  copy?: CampaignContent["faqSection"];
}

const fallbackContent = getLocaleContent();
const { faqs = buildFaqs(), copy = fallbackContent.faqSection } = Astro.props;
---

<section class={styles.faqBand} id="faq" aria-labelledby="faq-title" data-faq-root>
  <div class={styles.inner}>
    <div class={styles.heading}>
      <p class={styles.eyebrow}>{copy.eyebrow}</p>
      <h2 id="faq-title">
        <span>{copy.titlePrefix}</span>
        <strong>{copy.titleStrong}</strong>
      </h2>
    </div>

    <div class={styles.list}>
      {
        faqs.map((faq, index) => (
          <article class={styles.item} data-faq-item>
            <button
              class={styles.summary}
              type="button"
              aria-expanded="false"
              aria-controls={`faq-answer-${index}`}
              data-faq-trigger
            >
              <span class={styles.index} aria-hidden="true">
                {String(index + 1).padStart(2, "0")}
              </span>
              <span class={styles.question}>{faq.question}</span>
              <span class={styles.toggleIcon} aria-hidden="true">
                <Icon name="tabler:plus" size={24} />
              </span>
            </button>
            <div
              class={styles.answer}
              id={`faq-answer-${index}`}
              data-faq-panel
              hidden
            >
              <div class={styles.answerInner}>
                <p>{faq.answer}</p>
                {"link" in faq && faq.link && (
                  <a href={faq.link.href} target="_blank" rel="noreferrer">
                    {faq.link.label}
                  </a>
                )}
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <div class={styles.action}>
      <DonateButton variant="faq" label={copy.donateCta} />
    </div>
  </div>
</section>

<script>
  const initFaqSections = () => {
    const faqRoots = document.querySelectorAll<HTMLElement>("[data-faq-root]");

    faqRoots.forEach((root) => {
      if (root.dataset.faqReady === "true") return;
      root.dataset.faqReady = "true";

      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

      root.querySelectorAll<HTMLElement>("[data-faq-item]").forEach((item) => {
        const trigger = item.querySelector<HTMLButtonElement>("[data-faq-trigger]");
        const panel = item.querySelector<HTMLElement>("[data-faq-panel]");

        if (!trigger || !panel) return;

        const setPanelHeight = (height: number | "auto") => {
          panel.style.height = height === "auto" ? "auto" : `${height}px`;
        };

        const openPanel = () => {
          trigger.setAttribute("aria-expanded", "true");
          item.dataset.open = "true";
          panel.hidden = false;
          panel.dataset.open = "true";

          if (reduceMotion.matches) {
            setPanelHeight("auto");
            return;
          }

          setPanelHeight(0);
          window.requestAnimationFrame(() => {
            setPanelHeight(panel.scrollHeight);
          });
        };

        const closePanel = () => {
          trigger.setAttribute("aria-expanded", "false");
          delete item.dataset.open;
          delete panel.dataset.open;

          if (reduceMotion.matches) {
            panel.hidden = true;
            panel.style.height = "";
            return;
          }

          setPanelHeight(panel.getBoundingClientRect().height);
          window.requestAnimationFrame(() => {
            setPanelHeight(0);
          });
        };

        panel.addEventListener("transitionend", (event) => {
          if (event.target !== panel || event.propertyName !== "height") return;

          if (trigger.getAttribute("aria-expanded") === "true") {
            setPanelHeight("auto");
          } else {
            panel.hidden = true;
            panel.style.height = "";
          }
        });

        trigger.addEventListener("click", () => {
          if (trigger.getAttribute("aria-expanded") === "true") {
            closePanel();
          } else {
            openPanel();
          }
        });
      });
    });
  };

  initFaqSections();
  document.addEventListener("astro:page-load", initFaqSections);
</script>
