---
import { Icon } from "astro-icon/components";
import {
    optimizedImageSrc,
    optimizedImageSrcSet,
    staticOptimizedImageSrc,
} from "../data/optimized-images";
import type { CampaignContent } from "../data/campaign";
import ProgressMeter from "./ProgressMeter.astro";
import DonateButton from "./DonateButton.astro";
import styles from "./HeroSection.module.css";

interface Props {
    raised: number;
    goal: number;
    copy: CampaignContent["hero"];
    progressCopy: CampaignContent["progress"];
    organizerVideo?: {
        src: string;
        sourceUrl: string;
        title: string;
    };
}

const { raised, goal, copy, progressCopy, organizerVideo } = Astro.props;
const hasOrganizerVideo = Boolean(organizerVideo?.src);
const heroImageName = "venezuela-earthquake-hero-aid";
const heroWidths = [640, 960, 1280, 1680, 2240];
const heroSizes = "(max-width: 700px) 100vw, min(96vw, 1680px)";
const heroSrcSet = (format: "avif" | "webp" | "jpg") =>
    optimizedImageSrcSet(heroImageName, heroWidths, format);
const heroFallbackSrc = optimizedImageSrc(heroImageName, 1280, "jpg");
const heroPlaceholderSrc = staticOptimizedImageSrc(
    "venezuela-earthquake-hero-aid-lqip",
    "jpg",
);
---

<section class={styles.hero} aria-labelledby="hero-title">
    <div
        class={styles.media}
        aria-hidden="true"
        style={`--hero-placeholder-image: url("${heroPlaceholderSrc}")`}
    >
        <picture data-critical-picture>
            <source
                srcset={heroSrcSet("webp")}
                sizes={heroSizes}
                type="image/webp"
            />
            <img
                src={heroFallbackSrc}
                srcset={heroSrcSet("jpg")}
                sizes={heroSizes}
                alt=""
                width="1680"
                height="1120"
                decoding="async"
                loading="eager"
                fetchpriority="high"
                data-fallback-src={heroFallbackSrc}
                data-fallback-srcset={heroSrcSet("jpg")}
                data-fallback-sizes={heroSizes}
            />
        </picture>
    </div>

    <div class={styles.content}>
        <p class={styles.eyebrow}>{copy.eyebrow}</p>
        <h1 id="hero-title">
            <span>{copy.titlePrefix}</span>
            <strong>{copy.titleStrong}</strong>
        </h1>
        <p class={styles.lede}>{copy.lede}</p>
        <p class={styles.copy}>{copy.copy}</p>
        {
            hasOrganizerVideo && (
                <button
                    class={styles.videoCta}
                    type="button"
                    data-video-open
                    aria-haspopup="dialog"
                >
                    <span>{copy.videoCta}</span>
                </button>
            )
        }
    </div>

    <div class={styles.donationPanel} id="donar">
        <ProgressMeter raised={raised} goal={goal} copy={progressCopy} />

        <div class={styles.action}>
            <DonateButton variant="hero" label={copy.donateCta} />
            <p class={styles.paymentNote}>
                {copy.paymentNote}
                <span aria-label="PayPal">
                    <Icon name="tabler:brand-paypal" size={18} />
                </span>
                <span aria-label="Binance Pay">
                    <Icon name="tabler:brand-binance" size={18} />
                </span>
                <span aria-label="Pago Móvil">
                    <Icon name="tabler:device-mobile" size={18} />
                </span>
            </p>
        </div>
    </div>
</section>

{
    hasOrganizerVideo && organizerVideo && (
        <div class={styles.videoModal} data-video-modal aria-hidden="true">
            <button
                class={styles.videoBackdrop}
                type="button"
                data-video-close
                aria-label={copy.videoCloseLabel}
            />

            <section
                class={styles.videoDialog}
                role="dialog"
                aria-modal="true"
                aria-labelledby="organizer-video-title"
                tabindex="-1"
            >
                <header class={styles.videoHeader}>
                    <div>
                        <p class={styles.videoEyebrow}>{copy.videoModalEyebrow}</p>
                        <h2 id="organizer-video-title">{copy.videoModalTitle}</h2>
                    </div>
                    <button
                        class={styles.videoClose}
                        type="button"
                        data-video-close
                        aria-label={copy.videoCloseLabel}
                    >
                        <Icon name="tabler:x" size={22} />
                    </button>
                </header>

                <div class={styles.videoFrame} data-video-frame>
                    <video
                        data-video-player
                        title={organizerVideo.title}
                        playsinline
                        preload="none"
                    >
                        <source src={organizerVideo.src} type="video/mp4" />
                    </video>
                </div>

                {
                    organizerVideo.sourceUrl && (
                        <a
                            class={styles.videoSource}
                            href={organizerVideo.sourceUrl}
                            target="_blank"
                            rel="noreferrer"
                        >
                            <span>{copy.videoSourceLabel}</span>
                            <Icon name="tabler:external-link" size={17} />
                        </a>
                    )
                }
            </section>
        </div>
    )
}

<script>
    const initCriticalPictures = () => {
      document.querySelectorAll("[data-critical-picture]").forEach((picture) => {
        if (!(picture instanceof HTMLElement)) return;
        if (picture.dataset.criticalPictureReady === "true") return;
        picture.dataset.criticalPictureReady = "true";

        const image = picture.querySelector<HTMLImageElement>(
            "img[data-fallback-src]",
        );
        if (!(image instanceof HTMLImageElement)) return;

        let usedFallback = false;
        let watchdogId: number | undefined;

        const useFallback = () => {
            if (usedFallback || (image.complete && image.naturalWidth > 0)) return;

            usedFallback = true;
            picture.querySelectorAll("source").forEach((source) => source.remove());

            if (image.dataset.fallbackSrcset) {
                image.srcset = image.dataset.fallbackSrcset;
            }
            if (image.dataset.fallbackSizes) {
                image.sizes = image.dataset.fallbackSizes;
            }
            if (image.dataset.fallbackSrc) {
                image.src = image.dataset.fallbackSrc;
            }
        };

        if (image.complete && image.naturalWidth > 0) return;

        watchdogId = window.setTimeout(useFallback, 8000);
        image.addEventListener(
            "load",
            () => {
                if (watchdogId) window.clearTimeout(watchdogId);
            },
            { once: true },
        );
        image.addEventListener("error", useFallback, { once: true });
      });
    };

    initCriticalPictures();
    document.addEventListener("astro:page-load", initCriticalPictures);
</script>

<script>
    const initHeroVideoModal = () => {
      const videoModal = document.querySelector<HTMLElement>("[data-video-modal]");
      const videoWindow = window as Window & {
          __tpvHeroVideoAbortController?: AbortController;
      };

      if (!videoModal) {
        videoWindow.__tpvHeroVideoAbortController?.abort();
        return;
      }

      if (videoModal.dataset.videoReady !== "true") {
        videoWindow.__tpvHeroVideoAbortController?.abort();
        const videoController = new AbortController();
        videoWindow.__tpvHeroVideoAbortController = videoController;
        videoModal.dataset.videoReady = "true";

        const videoDialog = videoModal.querySelector<HTMLElement>(
            "[role='dialog']",
        );
        const videoPlayer =
            videoModal.querySelector<HTMLVideoElement>("[data-video-player]");
        const videoOpeners =
            document.querySelectorAll<HTMLElement>("[data-video-open]");
        const videoClosers =
            videoModal.querySelectorAll<HTMLElement>("[data-video-close]");
        let lastFocusedVideoElement: HTMLElement | null = null;
        let organizerPlayer: { pause: () => void } | null = null;
        let organizerPlayerPromise: Promise<void> | null = null;
        let plyrStylesheetPromise: Promise<void> | null = null;

        const loadPlyrStylesheet = () => {
            if (plyrStylesheetPromise) return plyrStylesheetPromise;

            plyrStylesheetPromise = new Promise<void>((resolve, reject) => {
                const existing = document.querySelector<HTMLLinkElement>(
                    'link[data-plyr-stylesheet="true"]',
                );

                if (existing) {
                    if (existing.sheet) {
                        resolve();
                    } else {
                        existing.addEventListener("load", () => resolve(), {
                            once: true,
                        });
                        existing.addEventListener(
                            "error",
                            () =>
                                reject(
                                    new Error(
                                        "Plyr stylesheet failed to load",
                                    ),
                                ),
                            { once: true },
                        );
                    }
                    return;
                }

                const link = document.createElement("link");
                link.rel = "stylesheet";
                link.href = "/vendor/plyr.css";
                link.dataset.plyrStylesheet = "true";
                link.addEventListener("load", () => resolve(), { once: true });
                link.addEventListener(
                    "error",
                    () =>
                        reject(
                            new Error("Plyr stylesheet failed to load"),
                        ),
                    { once: true },
                );
                document.head.append(link);
            });

            return plyrStylesheetPromise;
        };

        const prepareVideoPlayer = () => {
            if (!videoPlayer || organizerPlayer) return Promise.resolve();
            if (organizerPlayerPromise) return organizerPlayerPromise;

            organizerPlayerPromise = Promise.all([
                import("plyr"),
                loadPlyrStylesheet(),
            ]).then(([{ default: Plyr }]) => {
                organizerPlayer = new Plyr(videoPlayer, {
                    clickToPlay: true,
                    controls: [
                        "play-large",
                        "play",
                        "progress",
                        "current-time",
                        "mute",
                        "volume",
                    ],
                    fullscreen: {
                        enabled: false,
                        fallback: false,
                        iosNative: false,
                    },
                    hideControls: true,
                    invertTime: false,
                    keyboard: {
                        focused: true,
                        global: false,
                    },
                    ratio: "9:16",
                    resetOnEnd: true,
                    tooltips: {
                        controls: false,
                        seek: false,
                    },
                });
            });

            return organizerPlayerPromise;
        };

        const getVideoFocusable = () =>
            Array.from(
                videoModal.querySelectorAll<HTMLElement>(
                    'a[href], button:not([disabled]), video, [tabindex]:not([tabindex="-1"])',
                ),
            ).filter((el) => el.offsetParent !== null || el === videoDialog);

        const openVideo = () => {
            lastFocusedVideoElement = document.activeElement as HTMLElement;
            videoModal.setAttribute("aria-hidden", "false");
            document.body.classList.add("modal-open");
            if (videoPlayer) {
                videoPlayer.preload = "metadata";
                videoPlayer.load();
            }
            void prepareVideoPlayer();
            window.requestAnimationFrame(() => videoDialog?.focus());
        };

        const closeVideo = () => {
            videoModal.setAttribute("aria-hidden", "true");
            document.body.classList.remove("modal-open");
            if (videoPlayer) {
                organizerPlayer?.pause();
            }
            lastFocusedVideoElement?.focus();
        };

        videoOpeners.forEach((button) =>
            button.addEventListener("click", openVideo, {
                signal: videoController.signal,
            }),
        );
        videoClosers.forEach((button) =>
            button.addEventListener("click", closeVideo, {
                signal: videoController.signal,
            }),
        );
        videoModal
            .querySelector<HTMLElement>("[data-video-frame]")
            ?.addEventListener("dblclick", (event) => {
                event.preventDefault();
                event.stopPropagation();
            }, { signal: videoController.signal });

        document.addEventListener("keydown", (event) => {
            if (videoModal.getAttribute("aria-hidden") === "true") return;

            if (event.key === "Escape") {
                closeVideo();
                return;
            }

            if (event.key !== "Tab") return;

            const focusable = getVideoFocusable();
            if (focusable.length === 0) return;

            const first = focusable[0];
            const last = focusable[focusable.length - 1];

            if (event.shiftKey && document.activeElement === first) {
                event.preventDefault();
                last.focus();
            } else if (!event.shiftKey && document.activeElement === last) {
                event.preventDefault();
                first.focus();
            }
        }, { signal: videoController.signal });
      }
    };

    initHeroVideoModal();
    document.addEventListener("astro:page-load", initHeroVideoModal);
</script>
