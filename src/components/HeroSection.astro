---
import { Icon } from "astro-icon/components";
import { CirclePlay, Heart, X } from "@lucide/astro";
import ProgressMeter from "./ProgressMeter.astro";
import styles from "./HeroSection.module.css";

interface Props {
    raised: number;
    goal: number;
    organizerVideo?: {
        src: string;
        sourceUrl: string;
        title: string;
    };
}

const { raised, goal, organizerVideo } = Astro.props;
const hasOrganizerVideo = Boolean(organizerVideo?.src);
const heroWidths = [640, 960, 1280, 1680, 2240];
const heroSizes = "(max-width: 700px) 100vw, min(96vw, 1680px)";
const heroSrcSet = (format: "avif" | "webp" | "jpg") =>
    heroWidths
        .map(
            (width) =>
                `/images/optimized/venezuela-earthquake-hero-aid-${width}.${format} ${width}w`,
        )
        .join(", ");
---

<section class={styles.hero} aria-labelledby="hero-title">
    <div class={styles.media} aria-hidden="true">
        <picture>
            <source
                srcset={heroSrcSet("avif")}
                sizes={heroSizes}
                type="image/avif"
            />
            <source
                srcset={heroSrcSet("webp")}
                sizes={heroSizes}
                type="image/webp"
            />
            <img
                src="/images/optimized/venezuela-earthquake-hero-aid-1280.jpg"
                srcset={heroSrcSet("jpg")}
                sizes={heroSizes}
                alt=""
                width="1680"
                height="1120"
                decoding="async"
                loading="eager"
                fetchpriority="high"
            />
        </picture>
    </div>

    <div class={styles.content}>
        <p class={styles.eyebrow}>Emergencia por terremoto</p>
        <h1 id="hero-title">
            <span>Todos por</span>
            <strong>Venezuela</strong>
        </h1>
        <p class={styles.lede}>Ayuda para las zonas afectadas</p>
        <p class={styles.copy}>
            Jóvenes venezolanos organizaron esta recaudación para llevar
            insumos médicos, alimentos e hidratación a familias golpeadas por
            el terremoto, incluso en comunidades remotas.
        </p>
        {
            hasOrganizerVideo && (
                <button
                    class={styles.videoCta}
                    type="button"
                    data-video-open
                    aria-haspopup="dialog"
                >
                    <CirclePlay size={21} stroke-width={2.4} />
                    <span>Ver video de los organizadores</span>
                </button>
            )
        }
    </div>

    <div class={styles.donationPanel}>
        <ProgressMeter raised={raised} goal={goal} />

        <div class={styles.action}>
            <button class={styles.primaryCta} type="button" data-donate-open>
                <Heart size={26} fill="currentColor" stroke-width={2} />
                <span>Donar ahora</span>
            </button>
            <p class={styles.paymentNote}>
                Donación rápida y segura con
                <span aria-label="PayPal">
                    <Icon name="tabler:brand-paypal" size={18} />
                </span>
                <span aria-label="Binance Pay USDT">
                    <Icon name="tabler:brand-binance" size={18} />
                </span>
                <span aria-label="Pago Móvil">
                    <Icon name="tabler:device-mobile" size={18} />
                </span>
            </p>
        </div>
    </div>
</section>

{
    hasOrganizerVideo && organizerVideo && (
        <div class={styles.videoModal} data-video-modal aria-hidden="true">
            <button
                class={styles.videoBackdrop}
                type="button"
                data-video-close
                aria-label="Cerrar video"
            />

            <section
                class={styles.videoDialog}
                role="dialog"
                aria-modal="true"
                aria-labelledby="organizer-video-title"
                tabindex="-1"
            >
                <header class={styles.videoHeader}>
                    <div>
                        <p class={styles.videoEyebrow}>Organizadores</p>
                        <h2 id="organizer-video-title">Por qué nace esta campaña</h2>
                    </div>
                    <button
                        class={styles.videoClose}
                        type="button"
                        data-video-close
                        aria-label="Cerrar video"
                    >
                        <X size={22} stroke-width={2.2} />
                    </button>
                </header>

                <div class={styles.videoFrame} data-video-frame>
                    <video
                        data-video-player
                        title={organizerVideo.title}
                        playsinline
                        preload="none"
                    >
                        <source src={organizerVideo.src} type="video/mp4" />
                    </video>
                </div>

                {
                    organizerVideo.sourceUrl && (
                        <a
                            class={styles.videoSource}
                            href={organizerVideo.sourceUrl}
                            target="_blank"
                            rel="noreferrer"
                        >
                            <span>Abrir video original</span>
                            <Icon name="tabler:external-link" size={17} />
                        </a>
                    )
                }
            </section>
        </div>
    )
}

<script>
    const videoModal = document.querySelector<HTMLElement>("[data-video-modal]");

    if (videoModal && videoModal.dataset.videoReady !== "true") {
        videoModal.dataset.videoReady = "true";

        const videoDialog = videoModal.querySelector<HTMLElement>(
            "[role='dialog']",
        );
        const videoPlayer =
            videoModal.querySelector<HTMLVideoElement>("[data-video-player]");
        const videoOpeners =
            document.querySelectorAll<HTMLElement>("[data-video-open]");
        const videoClosers =
            videoModal.querySelectorAll<HTMLElement>("[data-video-close]");
        let lastFocusedVideoElement: HTMLElement | null = null;
        let organizerPlayer: { pause: () => void } | null = null;
        let organizerPlayerPromise: Promise<void> | null = null;
        let plyrStylesheetPromise: Promise<void> | null = null;

        const loadPlyrStylesheet = () => {
            if (plyrStylesheetPromise) return plyrStylesheetPromise;

            plyrStylesheetPromise = new Promise<void>((resolve, reject) => {
                const existing = document.querySelector<HTMLLinkElement>(
                    'link[data-plyr-stylesheet="true"]',
                );

                if (existing) {
                    if (existing.sheet) {
                        resolve();
                    } else {
                        existing.addEventListener("load", () => resolve(), {
                            once: true,
                        });
                        existing.addEventListener(
                            "error",
                            () =>
                                reject(
                                    new Error(
                                        "Plyr stylesheet failed to load",
                                    ),
                                ),
                            { once: true },
                        );
                    }
                    return;
                }

                const link = document.createElement("link");
                link.rel = "stylesheet";
                link.href = "/vendor/plyr.css";
                link.dataset.plyrStylesheet = "true";
                link.addEventListener("load", () => resolve(), { once: true });
                link.addEventListener(
                    "error",
                    () =>
                        reject(
                            new Error("Plyr stylesheet failed to load"),
                        ),
                    { once: true },
                );
                document.head.append(link);
            });

            return plyrStylesheetPromise;
        };

        const prepareVideoPlayer = () => {
            if (!videoPlayer || organizerPlayer) return Promise.resolve();
            if (organizerPlayerPromise) return organizerPlayerPromise;

            organizerPlayerPromise = Promise.all([
                import("plyr"),
                loadPlyrStylesheet(),
            ]).then(([{ default: Plyr }]) => {
                organizerPlayer = new Plyr(videoPlayer, {
                    clickToPlay: true,
                    controls: [
                        "play-large",
                        "play",
                        "progress",
                        "current-time",
                        "mute",
                        "volume",
                    ],
                    fullscreen: {
                        enabled: false,
                        fallback: false,
                        iosNative: false,
                    },
                    hideControls: true,
                    invertTime: false,
                    keyboard: {
                        focused: true,
                        global: false,
                    },
                    ratio: "9:16",
                    resetOnEnd: true,
                    tooltips: {
                        controls: false,
                        seek: false,
                    },
                });
            });

            return organizerPlayerPromise;
        };

        const getVideoFocusable = () =>
            Array.from(
                videoModal.querySelectorAll<HTMLElement>(
                    'a[href], button:not([disabled]), video, [tabindex]:not([tabindex="-1"])',
                ),
            ).filter((el) => el.offsetParent !== null || el === videoDialog);

        const openVideo = () => {
            lastFocusedVideoElement = document.activeElement as HTMLElement;
            videoModal.setAttribute("aria-hidden", "false");
            document.body.classList.add("modal-open");
            if (videoPlayer) {
                videoPlayer.preload = "metadata";
                videoPlayer.load();
            }
            void prepareVideoPlayer();
            window.requestAnimationFrame(() => videoDialog?.focus());
        };

        const closeVideo = () => {
            videoModal.setAttribute("aria-hidden", "true");
            document.body.classList.remove("modal-open");
            if (videoPlayer) {
                organizerPlayer?.pause();
            }
            lastFocusedVideoElement?.focus();
        };

        videoOpeners.forEach((button) =>
            button.addEventListener("click", openVideo),
        );
        videoClosers.forEach((button) =>
            button.addEventListener("click", closeVideo),
        );
        videoModal
            .querySelector<HTMLElement>("[data-video-frame]")
            ?.addEventListener("dblclick", (event) => {
                event.preventDefault();
                event.stopPropagation();
            });

        document.addEventListener("keydown", (event) => {
            if (videoModal.getAttribute("aria-hidden") === "true") return;

            if (event.key === "Escape") {
                closeVideo();
                return;
            }

            if (event.key !== "Tab") return;

            const focusable = getVideoFocusable();
            if (focusable.length === 0) return;

            const first = focusable[0];
            const last = focusable[focusable.length - 1];

            if (event.shiftKey && document.activeElement === first) {
                event.preventDefault();
                last.focus();
            } else if (!event.shiftKey && document.activeElement === last) {
                event.preventDefault();
                first.focus();
            }
        });
    }
</script>
