---
import { ChevronLeft, ChevronRight } from "@lucide/astro";
import styles from "./DevastationCarousel.module.css";

const apGallery =
  "https://apnews.com/photo-gallery/photos-venezuela-earthquake-missing-rescue-searches-b9bfceacb7b53f06e2e0b54b85461b26";

// Arc: la escala del daño → la búsqueda → la pérdida → la comunidad que responde.
const slides = [
  {
    src: "/images/venezuela-earthquake-la-guaira-collapse.jpg",
    alt: "Vista aérea de un edificio residencial colapsado por completo tras el terremoto en La Guaira.",
    width: 1800,
    height: 1200,
    place: "La Guaira",
    title: "Una manzana entera, en el suelo",
    caption: "Edificios completos colapsaron sobre vecindarios habitados. La búsqueda continúa entre los escombros.",
    credit: "AP / Ariana Cubillos",
    creditUrl: apGallery
  },
  {
    src: "/images/venezuela-earthquake-rescue.jpg",
    alt: "Vecinos y rescatistas buscan personas entre los escombros de un edificio derrumbado durante la noche.",
    width: 1200,
    height: 800,
    place: "Caracas",
    title: "La búsqueda no para de noche",
    caption: "Rescatistas y vecinos remueven losas a mano para llegar a quienes siguen atrapados.",
    credit: "AP / Ariana Cubillos",
    creditUrl: apGallery
  },
  {
    src: "/images/venezuela-earthquake-rubble.jpg",
    alt: "Una mujer permanece de pie sobre los escombros de un edificio destruido junto a un auto aplastado.",
    width: 1200,
    height: 800,
    place: "Catia, Caracas",
    title: "Lo que quedó de un hogar",
    caption: "Familias regresan a lo que era su casa y encuentran solo ruinas donde vivían.",
    credit: "AP / Ariana Cubillos",
    creditUrl: apGallery
  },
  {
    src: "/images/venezuela-earthquake-caracas-neighbors.jpg",
    alt: "Vecinos retiran escombros con escobas y palas dentro de un edificio dañado por el terremoto.",
    width: 1800,
    height: 1200,
    place: "Caracas",
    title: "La comunidad empieza a levantarse",
    caption: "Con escobas y palas, los vecinos despejan lo que el sismo dejó atrás.",
    credit: "AP / Ariana Cubillos",
    creditUrl: apGallery
  }
];

const total = String(slides.length).padStart(2, "0");
---

<section class={styles.section} id="impacto" aria-labelledby="devastation-title">
  <div class={styles.head}>
    <div class={styles.intro}>
      <p class={styles.eyebrow}>Lo que está pasando</p>
      <h2 id="devastation-title">
        <span>El país</span>
        <strong>bajo escombros</strong>
      </h2>
      <p class={styles.lede}>
        Estas son imágenes de prensa de los días posteriores al terremoto.
        Detrás de cada escombro hay comunidades enteras que hoy necesitan agua,
        medicinas y un lugar donde dormir.
      </p>
    </div>

    <div class={styles.factline}>
      <span class={styles.fact}><b>M 7,5</b>Magnitud</span>
      <span class={styles.fact}><b>10 km</b>Profundidad</span>
      <span class={styles.fact}><b>24 jun</b>2026</span>
      <span class={styles.fact}><b>Yumare</b>Epicentro</span>
      <span class={styles.factSource}>Datos: USGS</span>
    </div>
  </div>

  <div class={styles.carousel} data-devastation-carousel>
    <div class={styles.stage} data-carousel-stage aria-live="polite">
      {
        slides.map((slide, index) => (
          <figure
            class={styles.slide}
            data-carousel-slide
            data-state={index === 0 ? "active" : "hidden"}
            aria-hidden={index === 0 ? "false" : "true"}
          >
            <img
              src={slide.src}
              alt={slide.alt}
              width={slide.width}
              height={slide.height}
              loading={index === 0 ? "eager" : "lazy"}
              decoding="async"
            />
            <figcaption class={styles.caption}>
              <div class={styles.captionHead}>
                <span class={styles.place}>{slide.place}</span>
                <span class={styles.frame}>
                  <b>{String(index + 1).padStart(2, "0")}</b> / {total}
                </span>
              </div>
              <h3>{slide.title}</h3>
              <p class={styles.captionText}>{slide.caption}</p>
              <a class={styles.credit} href={slide.creditUrl} target="_blank" rel="noreferrer">
                {slide.credit}
              </a>
            </figcaption>
          </figure>
        ))
      }

      <div class={styles.controls} aria-label="Controles del registro visual">
        <button class={styles.control} type="button" aria-label="Ver imagen anterior" data-carousel-prev>
          <ChevronLeft size={22} strokeWidth={2.4} />
        </button>
        <button class={styles.control} type="button" aria-label="Ver imagen siguiente" data-carousel-next>
          <ChevronRight size={22} strokeWidth={2.4} />
        </button>
      </div>

      <div class={styles.progress} aria-label="Seleccionar imagen">
        {
          slides.map((slide, index) => (
            <button
              class={styles.progressItem}
              type="button"
              aria-label={`Ver imagen ${index + 1}: ${slide.title}`}
              aria-current={index === 0 ? "true" : "false"}
              data-carousel-dot
            >
              <span aria-hidden="true" />
            </button>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  const carouselRoots = document.querySelectorAll("[data-devastation-carousel]");

  carouselRoots.forEach((carousel) => {
    if (!(carousel instanceof HTMLElement) || carousel.dataset.ready === "true") return;
    carousel.dataset.ready = "true";

    const slides = Array.from(carousel.querySelectorAll("[data-carousel-slide]"));
    const dots = Array.from(carousel.querySelectorAll("[data-carousel-dot]"));
    const stage = carousel.querySelector("[data-carousel-stage]");
    const prev = carousel.querySelector("[data-carousel-prev]");
    const next = carousel.querySelector("[data-carousel-next]");
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let activeIndex = 0;
    let autoplayId: number | undefined;

    const setActive = (index: number) => {
      activeIndex = (index + slides.length) % slides.length;

      slides.forEach((slide, slideIndex) => {
        const isActive = slideIndex === activeIndex;
        slide.setAttribute("data-state", isActive ? "active" : "hidden");
        slide.setAttribute("aria-hidden", isActive ? "false" : "true");
      });

      dots.forEach((dot, dotIndex) => {
        // Reset, then re-apply so the active scrubber slot restarts its fill.
        dot.setAttribute("aria-current", "false");
        if (dotIndex === activeIndex) {
          void (dot as HTMLElement).offsetWidth;
          dot.setAttribute("aria-current", "true");
        }
      });
    };

    const stopAutoplay = () => {
      if (autoplayId) window.clearInterval(autoplayId);
    };

    const startAutoplay = () => {
      if (reducedMotion) return;
      stopAutoplay();
      autoplayId = window.setInterval(() => setActive(activeIndex + 1), 6200);
    };

    const go = (index: number) => {
      setActive(index);
      startAutoplay();
    };

    prev?.addEventListener("click", () => go(activeIndex - 1));
    next?.addEventListener("click", () => go(activeIndex + 1));
    dots.forEach((dot, dotIndex) => dot.addEventListener("click", () => go(dotIndex)));

    carousel.addEventListener("keydown", (event) => {
      if (event.key === "ArrowLeft") {
        event.preventDefault();
        go(activeIndex - 1);
      }
      if (event.key === "ArrowRight") {
        event.preventDefault();
        go(activeIndex + 1);
      }
    });

    // Pointer swipe keeps the photographs navigable by touch.
    let swipeStartX: number | null = null;
    stage?.addEventListener("pointerdown", (event) => {
      swipeStartX = (event as PointerEvent).clientX;
    });
    stage?.addEventListener("pointerup", (event) => {
      if (swipeStartX === null) return;
      const delta = (event as PointerEvent).clientX - swipeStartX;
      if (Math.abs(delta) > 44) go(activeIndex + (delta < 0 ? 1 : -1));
      swipeStartX = null;
    });

    carousel.addEventListener("mouseenter", stopAutoplay);
    carousel.addEventListener("mouseleave", startAutoplay);
    carousel.addEventListener("focusin", stopAutoplay);
    carousel.addEventListener("focusout", (event) => {
      if (!carousel.contains(event.relatedTarget as Node)) startAutoplay();
    });

    setActive(0);
    startAutoplay();
  });
</script>
