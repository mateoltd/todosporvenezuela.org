---
import type { CampaignContent } from "../data/campaign";
import styles from "./SiteFooter.module.css";

interface Props {
  copy: CampaignContent["footer"];
}

const { copy } = Astro.props;
---

<footer class={styles.siteFooter} aria-label={copy.ariaLabel}>
  <div class={styles.inner}>
    <p>{copy.madeWithLove}</p>
    <p>{copy.costNote}</p>
  </div>

  <div class={styles.flagBand} aria-hidden="true">
    <span></span>
    <span></span>
    <span></span>
    <span></span>
    <span></span>
    <span></span>
    <span></span>
    <span></span>
  </div>
</footer>
