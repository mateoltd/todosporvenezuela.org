---
import type { LanguageSelectorOption } from "../i18n/config";
import styles from "./LanguageSelector.module.css";

interface Props {
  currentLocale: LanguageSelectorOption["locale"];
  label: string;
  options: LanguageSelectorOption[];
  class?: string;
}

const { currentLocale, label, options, class: className } = Astro.props;
---

<div class:list={[styles.root, className]} role="group" aria-label={label}>
  {
    options.map((option, index) => {
      const isCurrent = option.locale === currentLocale;

      return (
        <>
          {index > 0 && <span class={styles.divider} aria-hidden="true" />}
          <a
            class={styles.lang}
            href={option.href}
            hreflang={option.locale}
            lang={option.locale}
            aria-current={isCurrent ? "true" : undefined}
            data-current={isCurrent ? "" : undefined}
            data-locale={option.locale}
          >
            <span class={styles.code}>{option.shortLabel}</span>
          </a>
        </>
      );
    })
  }
</div>

<script is:inline>
  (() => {
    const saveClientPreference = (locale) => {
      const secureFlag = window.location.protocol === "https:" ? "; Secure" : "";
      document.cookie = `tpv_locale=${encodeURIComponent(locale)}; Path=/; Max-Age=31536000; SameSite=Lax${secureFlag}`;
    };

    const initLanguageSelectors = () => {
      document.querySelectorAll("[data-locale]").forEach((link) => {
        if (!(link instanceof HTMLAnchorElement) || link.dataset.localeBound === "true") {
          return;
        }
        link.dataset.localeBound = "true";
        link.addEventListener("click", () => {
          const locale = link.getAttribute("data-locale");
          if (locale) saveClientPreference(locale);
        });
      });
    };

    initLanguageSelectors();

    if (!window.__tpvLanguageSelectorInitBound) {
      window.__tpvLanguageSelectorInitBound = true;
      document.addEventListener("astro:page-load", initLanguageSelectors);
    }
  })();
</script>
