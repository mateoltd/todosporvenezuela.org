---
import { Icon } from "astro-icon/components";
import type { CampaignContent } from "../data/campaign";
import type { LanguageSelectorOption, SupportedLocale } from "../i18n/config";
import LanguageSelector from "./LanguageSelector.astro";
import DonateButton from "./DonateButton.astro";
import styles from "./SiteHeader.module.css";

interface Props {
  copy: CampaignContent["header"];
  links: {
    home: string;
    impact: string;
    organizers: string;
    transparency: string;
    faq: string;
  };
  currentLocale: SupportedLocale;
  languageOptions: LanguageSelectorOption[];
}

const { copy, links, currentLocale, languageOptions } = Astro.props;
---

<header class={styles.siteHeader} data-header data-scrolled-class={styles.scrolled}>
  <a class={styles.brand} href={links.home} aria-label={copy.brandAriaLabel}>
    <span class={styles.brandMark} aria-hidden="true">
      <picture>
        <source srcset="/images/tpv-emblem.webp" type="image/webp" />
        <img
          src="/images/tpv-emblem.png"
          alt=""
          width="256"
          height="256"
          decoding="async"
        />
      </picture>
    </span>
    <span class={styles.brandText}>{copy.brandText.line1}<br />{copy.brandText.line2}</span>
  </a>

  <button
    class={styles.menuToggle}
    type="button"
    aria-label={copy.menuOpenLabel}
    aria-controls="site-navigation"
    aria-expanded="false"
    data-menu-toggle
    data-nav-open-class={styles.navOpen}
    data-menu-open-label={copy.menuOpenLabel}
    data-menu-close-label={copy.menuCloseLabel}
  >
    <span class={styles.menuIconOpen} aria-hidden="true">
      <Icon name="tabler:menu-2" size={22} />
    </span>
    <span class={styles.menuIconClose} aria-hidden="true">
      <Icon name="tabler:x" size={22} />
    </span>
  </button>

  <nav id="site-navigation" class={styles.primaryNav} aria-label={copy.navLabel} data-nav>
    <a href={links.impact}>{copy.nav.impact}</a>
    <a href={links.organizers}>{copy.nav.organizers}</a>
    <a href={links.transparency}>{copy.nav.transparency}</a>
    <a href={links.faq}>{copy.nav.faq}</a>
  </nav>

  <div class={styles.headerActions}>
    <LanguageSelector
      currentLocale={currentLocale}
      label={copy.languageSwitchLabel}
      options={languageOptions}
    />

    <DonateButton
      variant="compact"
      label={copy.donateCompact}
      ariaLabel={copy.donateAriaLabel}
    />
  </div>

  <span class={styles.flagRule} aria-hidden="true"></span>
</header>

<script>
  const initSiteHeader = () => {
    const header = document.querySelector("[data-header]");
    if (!(header instanceof HTMLElement) || header.dataset.headerReady === "true") return;

    const headerWindow = window as Window & {
      __tpvSiteHeaderAbortController?: AbortController;
    };

    headerWindow.__tpvSiteHeaderAbortController?.abort();
    const headerController = new AbortController();
    headerWindow.__tpvSiteHeaderAbortController = headerController;
    header.dataset.headerReady = "true";

    const nav = header.querySelector("[data-nav]");
    const menuToggle = header.querySelector("[data-menu-toggle]");
    const donateButton = header.querySelector("[data-donate-open]");
    const navOpenClass = menuToggle?.getAttribute("data-nav-open-class");
    const menuOpenLabel = menuToggle?.getAttribute("data-menu-open-label") ?? "Open navigation menu";
    const menuCloseLabel = menuToggle?.getAttribute("data-menu-close-label") ?? "Close navigation menu";
    const desktopNav = window.matchMedia("(min-width: 861px)");

    const setMenuState = (isOpen: boolean, shouldFocusToggle = false) => {
      if (!(nav instanceof HTMLElement) || !(menuToggle instanceof HTMLButtonElement) || !navOpenClass) {
        return;
      }

      nav.classList.toggle(navOpenClass, isOpen);
      menuToggle.setAttribute("aria-expanded", String(isOpen));
      menuToggle.setAttribute(
        "aria-label",
        isOpen ? menuCloseLabel : menuOpenLabel
      );

      if (desktopNav.matches) {
        nav.removeAttribute("inert");
      } else {
        nav.toggleAttribute("inert", !isOpen);
      }

      if (shouldFocusToggle) menuToggle.focus();
    };

    const closeMenu = (shouldFocusToggle = false) => {
      setMenuState(false, shouldFocusToggle);
    };

    menuToggle?.addEventListener("click", () => {
      const isOpen = menuToggle.getAttribute("aria-expanded") === "true";
      setMenuState(!isOpen);
    }, { signal: headerController.signal });

    nav?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => closeMenu(), {
        signal: headerController.signal
      });
    });

    donateButton?.addEventListener("click", () => closeMenu(), {
      signal: headerController.signal
    });

    document.addEventListener("click", (event) => {
      const isOpen = menuToggle?.getAttribute("aria-expanded") === "true";
      if (isOpen && event.target instanceof Node && !header.contains(event.target)) {
        closeMenu();
      }
    }, { signal: headerController.signal });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && menuToggle?.getAttribute("aria-expanded") === "true") {
        closeMenu(true);
      }
    }, { signal: headerController.signal });

    const syncMenuForViewport = () => {
      closeMenu();
      if (desktopNav.matches && nav instanceof HTMLElement) {
        nav.removeAttribute("inert");
      }
    };

    desktopNav.addEventListener("change", syncMenuForViewport, {
      signal: headerController.signal
    });
    syncMenuForViewport();

    const scrolledClass = header.getAttribute("data-scrolled-class");
    let isScrolled = false;
    const onScroll = () => {
      if (!scrolledClass) return;
      const nextScrolled = window.scrollY > 8;
      if (nextScrolled === isScrolled) return;
      isScrolled = nextScrolled;
      header.classList.toggle(scrolledClass, isScrolled);
    };
    isScrolled = window.scrollY > 8;
    if (scrolledClass) header.classList.toggle(scrolledClass, isScrolled);
    onScroll();
    window.addEventListener("scroll", onScroll, {
      passive: true,
      signal: headerController.signal
    });
  };

  initSiteHeader();
  document.addEventListener("astro:page-load", initSiteHeader);
</script>
