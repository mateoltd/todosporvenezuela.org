---
import { Icon } from "astro-icon/components";
import MethodItem from "./MethodItem.astro";
import "../styles/donation-modal.css";

interface AmountOption {
  value: number;
  note: string;
  popular?: boolean;
}

interface PagoMovil {
  banco: string;
  telefono: string;
  documento: string;
  titular?: string;
  contacto?: string;
}

interface Binance {
  payId: string;
}

interface PayPalDonate {
  env: "production" | "sandbox";
  hostedButtonId: string;
  business?: string;
  image: {
    src: string;
    alt: string;
    title: string;
  };
}

interface Props {
  /** Fallback PayPal donate URL. The selected amount is appended client-side. */
  paypalUrl?: string;
  paypal?: PayPalDonate;
  amounts?: AmountOption[];
  pagoMovil?: PagoMovil;
  binance?: Binance;
}

const {
  paypalUrl = "https://www.paypal.com/donate",
  paypal = {
    env: "production",
    hostedButtonId: "",
    image: {
      src: "https://www.paypalobjects.com/en_US/i/btn/btn_donateCC_LG.gif",
      alt: "Donate with PayPal button",
      title: "PayPal - The safer, easier way to pay online!"
    }
  },
  amounts = [
    { value: 5, note: "Hidratación para quien lo necesita" },
    { value: 10, note: "Alimentación básica", popular: true },
    { value: 20, note: "Insumos médicos y primeros auxilios" },
    { value: 35, note: "Apoyo para zonas remotas" }
  ],
  // Datos oficiales pendientes: déjalos vacíos para mostrar el estado
  // "Disponible muy pronto"; al confirmar las cuentas, complétalos aquí.
  pagoMovil = { banco: "", telefono: "", documento: "", titular: "", contacto: "" },
  binance = { payId: "" }
} = Astro.props;

const defaultAmount = amounts.find((a) => a.popular)?.value ?? amounts[0]?.value ?? 10;

const usd = (value: number) =>
  new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: "USD",
    maximumFractionDigits: 0
  }).format(value);

// Métodos de pago. Internacional se lista directo; los pagos locales se
// eligen por país en un desplegable (hoy solo Venezuela, pero admite más).
type Method = {
  id: string;
  name: string;
  icon: string;
  desc: string;
  lead: string;
  fields: { label: string; value: string }[];
  steps: string[];
  action: "paypal" | "confirm";
  actionLabel: string;
};

const internationalMethods: Method[] = [
  {
    id: "paypal",
    name: "PayPal",
    icon: "tabler:brand-paypal",
    desc: "Tarjeta o cuenta PayPal",
    lead: "Para aportar desde el exterior, te llevamos a PayPal. Puedes pagar con tarjeta o cuenta PayPal.",
    fields: [],
    steps: [
      "Toca el botón de PayPal para abrir la ventana segura.",
      "Confirma el monto y completa el pago.",
      "Tu aporte ayudará a comprar insumos, alimentos e hidratación."
    ],
    action: "paypal",
    actionLabel: "Ir a PayPal"
  },
  {
    id: "binance",
    name: "Binance Pay",
    icon: "tabler:brand-binance",
    desc: "USDT, sin comisiones bancarias",
    lead: "Envía tu aporte en USDT por Binance Pay. Es una opción directa para donar desde Venezuela o desde el exterior.",
    fields: [
      { label: "Binance Pay ID", value: binance.payId },
      { label: "Moneda", value: binance.payId ? "USDT" : "" }
    ],
    steps: [
      "Abre Binance y entra a la sección Pay.",
      "Toca Enviar y pega el Pay ID.",
      "Envía el monto en USDT y conserva tu comprobante."
    ],
    action: "confirm",
    actionLabel: "Ya hice mi pago"
  }
];

const pagoMovilFields = [
  { label: "Banco", value: pagoMovil.banco },
  { label: "Teléfono", value: pagoMovil.telefono },
  { label: "Cédula o RIF", value: pagoMovil.documento },
  ...(pagoMovil.titular ? [{ label: "Titular", value: pagoMovil.titular }] : []),
  ...(pagoMovil.contacto ? [{ label: "Contacto", value: pagoMovil.contacto }] : [])
];

const pagoMovilSteps = [
  "Abre la app de tu banco y entra a Pago Móvil.",
  "Ingresa el banco, teléfono y Cédula/RIF de arriba.",
  "Envía el monto equivalente en bolívares y conserva tu comprobante.",
  ...(pagoMovil.contacto ? ["Usa el contacto si necesitas consultar o confirmar el pago."] : [])
];

const localCountries: { id: string; name: string; flag: string; methods: Method[] }[] = [
  {
    id: "ve",
    name: "Venezuela",
    flag: "circle-flags:ve",
    methods: [
      {
        id: "pagomovil",
        name: "Pago Móvil",
        icon: "tabler:device-mobile",
        desc: "Transferencia en bolívares",
        lead: "Aporta en bolívares desde la app de tu banco. Es la opción local para quienes están en Venezuela.",
        fields: pagoMovilFields,
        steps: pagoMovilSteps,
        action: "confirm",
        actionLabel: "Ya hice mi pago"
      }
    ]
  }
];
---

<div
  class="dm"
  data-donate-modal
  data-step="1"
  data-paypal-url={paypalUrl}
  data-paypal-env={paypal.env}
  data-paypal-hosted-button-id={paypal.hostedButtonId}
  data-paypal-business={paypal.business}
  data-paypal-image-src={paypal.image.src}
  data-paypal-image-alt={paypal.image.alt}
  data-paypal-image-title={paypal.image.title}
  aria-hidden="true"
>
  <div class="dm__backdrop" data-donate-close></div>

  <section
    class="dm__panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="dm-title"
    tabindex="-1"
  >
    <span class="dm__handle" aria-hidden="true"></span>

    <!-- Top bar: back · tricolor progress · close -->
    <header class="dm__bar">
      <button class="dm__iconbtn dm__back" type="button" aria-label="Volver" data-back disabled>
        <Icon name="tabler:arrow-left" size={20} />
      </button>

      <div class="dm__bands" aria-hidden="true">
        <span class="dm__band dm__band--1"></span>
        <span class="dm__band dm__band--2"></span>
        <span class="dm__band dm__band--3"></span>
      </div>

      <button class="dm__iconbtn dm__close" type="button" aria-label="Cerrar" data-donate-close>
        <Icon name="tabler:x" size={20} />
      </button>
    </header>

    <div class="dm__scroll">
      <!-- STEP 1 · Monto -->
      <div class="dm__step is-active" data-panel="1">
        <div class="dm__step-head">
          <h2 class="dm__title" id="dm-title">¿Cuánto quieres aportar?</h2>
          <p class="dm__lead">
            Tu aporte ayuda a comprar insumos médicos, alimentación e hidratación
            para personas necesitadas, incluso en zonas remotas.
          </p>
        </div>

        <div class="dm__amounts" role="group" aria-label="Elige un monto">
          {
            amounts.map((amount) => (
              <button
                type="button"
                class:list={["dm__amount", { "is-active": amount.value === defaultAmount }]}
                data-amount={amount.value}
                aria-pressed={amount.value === defaultAmount ? "true" : "false"}
              >
                {amount.popular && <span class="dm__amount-tag">Más elegido</span>}
                <span class="dm__amount-value">{usd(amount.value)}</span>
                <span class="dm__amount-note">{amount.note}</span>
              </button>
            ))
          }
        </div>

        <label class="dm__custom">
          <span>Otro monto en dólares</span>
          <input
            type="number"
            min="1"
            step="1"
            inputmode="numeric"
            placeholder="Escribe un monto"
            data-custom-amount
          />
        </label>

        <button class="dm__cta" type="button" data-next>
          Continuar
          <Icon name="tabler:chevron-right" size={20} />
        </button>
      </div>

      <!-- STEP 2 · Pagar -->
      <div class="dm__step" data-panel="2">
        <div class="dm__step-head">
          <p class="dm__amountchip">
            Tu aporte
            <strong data-amount-display>{usd(defaultAmount)}</strong>
          </p>
          <h2 class="dm__title">¿Cómo quieres pagar?</h2>
          <p class="dm__lead">Elige el método que te quede más fácil.</p>
        </div>

        <div class="dm__group">
          <p class="dm__group-label">
            <Icon name="tabler:world" size={15} />
            Desde cualquier país
          </p>

          <div class="dm__methods">
            {internationalMethods.map((method) => <MethodItem method={method} paypalUrl={paypalUrl} />)}
          </div>
        </div>

        <div class="dm__group">
          <p class="dm__group-label">
            <Icon name="tabler:map-pin" size={15} />
            Pago local
          </p>

          <!-- Each country is a collapsible section so donors who only want
               international methods can skip past it. Built for more countries. -->
          {
            localCountries.map((country, index) => (
              <div
                class:list={["dm__country", { "is-open": index === 0 }]}
                data-country-item={country.id}
              >
                <button
                  type="button"
                  class="dm__country-head"
                  data-country-toggle
                  aria-expanded={index === 0 ? "true" : "false"}
                >
                  <span class="dm__country-title">
                    <Icon class="dm__flag" name={country.flag} size={26} />
                    {country.name}
                  </span>
                  <Icon class="dm__country-chevron" name="tabler:chevron-down" size={20} />
                </button>

                <div class="dm__country-body">
                  <div class="dm__methods">
                    {country.methods.map((method) => (
                      <MethodItem method={method} paypalUrl={paypalUrl} />
                    ))}
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- DONE · Gracias -->
      <div class="dm__step dm__done" data-panel="done">
        <span class="dm__done-icon" aria-hidden="true">
          <Icon name="tabler:heart-handshake" size={36} />
        </span>
        <h2 class="dm__title">¡Gracias por tu aporte!</h2>
        <p class="dm__lead">
          Tu aporte suma en un momento difícil para Venezuela. Publicaremos
          reportes transparentes todos los días.
        </p>
        <button class="dm__cta" type="button" data-donate-close>Cerrar</button>
      </div>
    </div>
  </section>
</div>

<script>
  type StepId = "1" | "2" | "done";

  const modal = document.querySelector<HTMLElement>("[data-donate-modal]");

  if (modal) {
    const panel = modal.querySelector<HTMLElement>(".dm__panel");
    const scroll = modal.querySelector<HTMLElement>(".dm__scroll");
    const openers = document.querySelectorAll<HTMLElement>("[data-donate-open]");
    const closers = modal.querySelectorAll<HTMLElement>("[data-donate-close]");
    const backBtn = modal.querySelector<HTMLButtonElement>("[data-back]");
    const steps = modal.querySelectorAll<HTMLElement>("[data-panel]");
    const amountButtons = modal.querySelectorAll<HTMLElement>("[data-amount]");
    const customInput = modal.querySelector<HTMLInputElement>("[data-custom-amount]");
    const nextBtn = modal.querySelector<HTMLElement>("[data-next]");
    const methodItems = modal.querySelectorAll<HTMLElement>("[data-method-item]");
    const methodToggles = modal.querySelectorAll<HTMLElement>("[data-method-toggle]");
    const amountDisplays = modal.querySelectorAll<HTMLElement>("[data-amount-display]");
    const paypalLinks = modal.querySelectorAll<HTMLAnchorElement>("[data-paypal-link]");
    const paypalButton = modal.querySelector<HTMLElement>("[data-paypal-button]");
    const paypalFallback = modal.querySelector<HTMLAnchorElement>("[data-paypal-fallback]");
    const paypalStatus = modal.querySelector<HTMLElement>("[data-paypal-status]");
    const paypalBase = modal.getAttribute("data-paypal-url") ?? "";
    const paypalEnv = modal.getAttribute("data-paypal-env") || "production";
    const paypalHostedButtonId = modal.getAttribute("data-paypal-hosted-button-id") ?? "";
    const paypalBusiness = modal.getAttribute("data-paypal-business") ?? "";
    const paypalImageSrc = modal.getAttribute("data-paypal-image-src") ?? "";
    const paypalImageAlt = modal.getAttribute("data-paypal-image-alt") ?? "";
    const paypalImageTitle = modal.getAttribute("data-paypal-image-title") ?? "";

    const countryToggles = modal.querySelectorAll<HTMLElement>("[data-country-toggle]");

    let amount = Number(
      modal.querySelector<HTMLElement>("[data-amount].is-active")?.getAttribute("data-amount") ?? 10
    );
    let lastFocused: HTMLElement | null = null;
    let paypalRenderToken = 0;
    let paypalSdkPromise: Promise<void> | null = null;

    const paypalItemName =
      "Ayuda para insumos médicos, alimentación e hidratación en Venezuela.";
    const paypalItemNumber = "donacion-terremoto";
    const formatUsd = (value: number) => `$${Math.round(value)}`;
    const formatPaypalAmount = (value: number) =>
      Number.isFinite(value) ? Math.max(1, value).toFixed(2) : "1.00";

    type PayPalDonationButton = {
      render: (selector: string) => void;
    };

    type PayPalNamespace = {
      Donation: {
        Button: (options: Record<string, unknown>) => PayPalDonationButton;
      };
    };

    const getPayPal = () => (window as Window & { PayPal?: PayPalNamespace }).PayPal;

    const buildDonateStateUrl = (state: "paypal-completed" | "paypal-cancelled") => {
      const url = new URL(window.location.href);
      url.searchParams.set("donate", state);
      url.hash = "";
      return url.toString();
    };

    const buildPaypalFallbackUrl = () => {
      const url = new URL(paypalBase || "https://www.paypal.com/donate", window.location.href);
      if (paypalBusiness) {
        url.searchParams.delete("hosted_button_id");
        url.searchParams.set("business", paypalBusiness);
      } else if (paypalHostedButtonId) {
        url.searchParams.set("hosted_button_id", paypalHostedButtonId);
      }
      url.searchParams.set("amount", formatPaypalAmount(amount));
      url.searchParams.set("currency_code", "USD");
      url.searchParams.set("item_name", paypalItemName);
      url.searchParams.set("item_number", paypalItemNumber);
      url.searchParams.set("no_shipping", "1");
      url.searchParams.set("rm", "1");
      url.searchParams.set("return", buildDonateStateUrl("paypal-completed"));
      url.searchParams.set("cancel_return", buildDonateStateUrl("paypal-cancelled"));
      return url.toString();
    };

    const syncAmount = () => {
      amountDisplays.forEach((el) => (el.textContent = formatUsd(amount)));
      paypalLinks.forEach((link) => (link.href = buildPaypalFallbackUrl()));
      if (modal.querySelector('[data-method-item="paypal"]')?.classList.contains("is-open")) {
        renderPayPalButton();
      }
    };

    const collapseMethods = () => {
      methodItems.forEach((item) => item.classList.remove("is-open"));
      methodToggles.forEach((t) => t.setAttribute("aria-expanded", "false"));
    };

    const goToStep = (id: StepId) => {
      modal.setAttribute("data-step", id);
      steps.forEach((step) =>
        step.classList.toggle("is-active", step.getAttribute("data-panel") === id)
      );
      if (backBtn) backBtn.disabled = id !== "2";
      scroll?.scrollTo({ top: 0, behavior: "auto" });
    };

    const openMethod = (methodId: string) => {
      const item = modal.querySelector<HTMLElement>(`[data-method-item="${methodId}"]`);
      const toggle = modal.querySelector<HTMLElement>(`[data-method-toggle="${methodId}"]`);
      if (!item || !toggle) return;
      collapseMethods();
      item.classList.add("is-open");
      toggle.setAttribute("aria-expanded", "true");
      if (methodId === "paypal") renderPayPalButton();
    };

    // Reset to the default state: the first country open, the rest collapsed.
    const resetCountries = () => {
      countryToggles.forEach((toggle, index) => {
        const open = index === 0;
        toggle.closest<HTMLElement>("[data-country-item]")?.classList.toggle("is-open", open);
        toggle.setAttribute("aria-expanded", open ? "true" : "false");
      });
    };

    const goBack = () => {
      const current = modal.getAttribute("data-step");
      if (current === "2") goToStep("1");
    };

    const getFocusable = () =>
      Array.from(
        modal.querySelectorAll<HTMLElement>(
          'a[href], button:not([disabled]), input, [tabindex]:not([tabindex="-1"])'
        )
      ).filter((el) => el.offsetParent !== null || el === panel);

    const openModal = (options: { step?: StepId; methodId?: string } = {}) => {
      lastFocused = document.activeElement as HTMLElement;
      modal.setAttribute("aria-hidden", "false");
      document.body.classList.add("modal-open");
      collapseMethods();
      resetCountries();
      goToStep(options.step ?? "1");
      if (options.methodId) openMethod(options.methodId);
      window.requestAnimationFrame(() => panel?.focus());
    };

    const closeModal = () => {
      modal.setAttribute("aria-hidden", "true");
      document.body.classList.remove("modal-open");
      lastFocused?.focus();
    };

    const loadPayPalSdk = () => {
      if (getPayPal()) return Promise.resolve();
      if (paypalSdkPromise) return paypalSdkPromise;

      paypalSdkPromise = new Promise<void>((resolve, reject) => {
        const existing = document.querySelector<HTMLScriptElement>(
          'script[src="https://www.paypalobjects.com/donate/sdk/donate-sdk.js"]'
        );

        if (existing) {
          existing.addEventListener("load", () => resolve(), { once: true });
          existing.addEventListener("error", () => reject(new Error("PayPal SDK failed to load")), {
            once: true
          });
          return;
        }

        const script = document.createElement("script");
        script.src = "https://www.paypalobjects.com/donate/sdk/donate-sdk.js";
        script.setAttribute("charset", "UTF-8");
        script.addEventListener("load", () => resolve(), { once: true });
        script.addEventListener("error", () => reject(new Error("PayPal SDK failed to load")), {
          once: true
        });
        document.body.append(script);
      });

      return paypalSdkPromise;
    };

    const setPaypalStatus = (message: string, visible = true) => {
      if (!paypalStatus) return;
      paypalStatus.hidden = !visible;
      paypalStatus.textContent = message;
    };

    const renderPayPalButton = async () => {
      if (!paypalButton || (!paypalHostedButtonId && !paypalBusiness)) return;

      const token = ++paypalRenderToken;
      paypalButton.replaceChildren();
      paypalButton.classList.remove("is-loaded");
      paypalFallback?.classList.remove("is-visible");
      setPaypalStatus("Cargando PayPal...");

      try {
        await loadPayPalSdk();
        if (token !== paypalRenderToken) return;

        const paypal = getPayPal();
        if (!paypal) throw new Error("PayPal SDK unavailable");

        const config: Record<string, unknown> = {
          env: paypalEnv,
          amount: formatPaypalAmount(amount),
          currency_code: "USD",
          item_name: paypalItemName,
          item_number: paypalItemNumber,
          no_shipping: "1",
          rm: "1",
          return: buildDonateStateUrl("paypal-completed"),
          cancel_return: buildDonateStateUrl("paypal-cancelled"),
          image: {
            src: paypalImageSrc,
            alt: paypalImageAlt,
            title: paypalImageTitle
          },
          onComplete: () => goToStep("done")
        };

        if (paypalBusiness) {
          config.business = paypalBusiness;
        } else if (paypalHostedButtonId) {
          config.hosted_button_id = paypalHostedButtonId;
        }

        paypalButton.replaceChildren();
        paypal.Donation.Button(config).render(`#${paypalButton.id}`);
        paypalButton.classList.add("is-loaded");
        setPaypalStatus("", false);
      } catch {
        setPaypalStatus("No pudimos cargar el botón de PayPal aquí. Puedes abrirlo en una pestaña nueva.");
        paypalFallback?.classList.add("is-visible");
      }
    };

    const handleInitialDonateState = () => {
      const url = new URL(window.location.href);
      const donateState = url.searchParams.get("donate");

      if (donateState === "paypal-completed") {
        openModal({ step: "done" });
      } else if (donateState === "paypal-cancelled") {
        openModal({ step: "2", methodId: "paypal" });
      } else {
        return;
      }

      url.searchParams.delete("donate");
      window.history.replaceState({}, "", `${url.pathname}${url.search}${url.hash}`);
    };

    openers.forEach((btn) => btn.addEventListener("click", () => openModal()));
    closers.forEach((btn) => btn.addEventListener("click", closeModal));
    backBtn?.addEventListener("click", goBack);
    nextBtn?.addEventListener("click", () => goToStep("2"));

    amountButtons.forEach((btn) =>
      btn.addEventListener("click", () => {
        amountButtons.forEach((b) => {
          b.classList.remove("is-active");
          b.setAttribute("aria-pressed", "false");
        });
        btn.classList.add("is-active");
        btn.setAttribute("aria-pressed", "true");
        amount = Number(btn.getAttribute("data-amount"));
        if (customInput) customInput.value = "";
        syncAmount();
      })
    );

    customInput?.addEventListener("input", () => {
      const value = Number(customInput.value);
      if (value >= 1) {
        amount = value;
        amountButtons.forEach((b) => {
          b.classList.remove("is-active");
          b.setAttribute("aria-pressed", "false");
        });
        syncAmount();
      }
    });

    methodToggles.forEach((toggle) =>
      toggle.addEventListener("click", () => {
        const item = toggle.closest<HTMLElement>("[data-method-item]");
        if (!item) return;
        const willOpen = !item.classList.contains("is-open");
        collapseMethods();
        if (willOpen) {
          item.classList.add("is-open");
          toggle.setAttribute("aria-expanded", "true");
          if (toggle.getAttribute("data-method-toggle") === "paypal") renderPayPalButton();
          window.requestAnimationFrame(() =>
            item.scrollIntoView({ block: "nearest", behavior: "smooth" })
          );
        }
      })
    );

    countryToggles.forEach((toggle) =>
      toggle.addEventListener("click", () => {
        const item = toggle.closest<HTMLElement>("[data-country-item]");
        if (!item) return;
        const willOpen = !item.classList.contains("is-open");
        item.classList.toggle("is-open", willOpen);
        toggle.setAttribute("aria-expanded", willOpen ? "true" : "false");
      })
    );

    modal.querySelectorAll<HTMLElement>("[data-done]").forEach((btn) =>
      btn.addEventListener("click", () => {
        // Manual methods land on thank-you after the donor confirms they paid.
        window.setTimeout(() => goToStep("done"), btn.hasAttribute("href") ? 250 : 0);
      })
    );

    modal.querySelectorAll<HTMLElement>("[data-copy]").forEach((btn) =>
      btn.addEventListener("click", async () => {
        const value = btn.getAttribute("data-copy") ?? "";
        try {
          await navigator.clipboard.writeText(value);
        } catch {
          const range = document.createRange();
          range.selectNodeContents(btn);
          const sel = window.getSelection();
          sel?.removeAllRanges();
          sel?.addRange(range);
        }
        btn.classList.add("is-copied");
        const label = btn.getAttribute("aria-label") ?? "";
        btn.setAttribute("aria-label", "Copiado");
        window.setTimeout(() => {
          btn.classList.remove("is-copied");
          btn.setAttribute("aria-label", label);
        }, 1600);
      })
    );

    document.addEventListener("keydown", (event) => {
      if (modal.getAttribute("aria-hidden") === "true") return;
      if (event.key === "Escape") {
        closeModal();
        return;
      }
      if (event.key === "Tab") {
        const focusable = getFocusable();
        if (focusable.length === 0) return;
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (event.shiftKey && document.activeElement === first) {
          event.preventDefault();
          last.focus();
        } else if (!event.shiftKey && document.activeElement === last) {
          event.preventDefault();
          first.focus();
        }
      }
    });

    syncAmount();
    handleInitialDonateState();
  }
</script>
