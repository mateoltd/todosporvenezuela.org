---
import { Icon } from "astro-icon/components";
import {
  getLocaleContent,
  type CampaignContent,
  type CampaignOrganizer,
} from "../data/campaign";
import styles from "./OrganizersSection.module.css";

interface Props {
  copy?: CampaignContent["organizersSection"];
  organizers?: CampaignOrganizer[];
}

const fallbackContent = getLocaleContent();
const {
  copy = fallbackContent.organizersSection,
  organizers = fallbackContent.organizers,
} = Astro.props;
---

<section class={styles.section} id="transparencia" aria-labelledby="organizers-title">
  <div class={styles.inner}>
    <div class={styles.heading}>
      <p class={styles.eyebrow}>{copy.eyebrow}</p>
      <h2 id="organizers-title">
        <span>{copy.titlePrefix} <strong>{copy.titleStrong}</strong></span>
      </h2>
      <p>
        {copy.bodyPrefix} {copy.affiliationText}.
      </p>

      <aside class={styles.callout}>
        <span class={styles.calloutIcon} aria-hidden="true">
          <Icon name="tabler:heart-handshake" size={28} />
        </span>
        <p>{copy.callout}</p>
      </aside>
    </div>

    <div class={styles.roster}>
      {
        organizers.map((person) => (
          <article class={styles.person} style={`--person-accent: ${person.accent};`}>
            <a
              class={styles.photoWrap}
              href={person.instagram}
              target="_blank"
              rel="noreferrer"
              aria-label={copy.instagramLabel.replace("{name}", person.name)}
            >
              <picture>
                <source srcset={`${person.image}.webp`} type="image/webp" />
                <img
                  class={styles.photo}
                  src={`${person.image}.jpg`}
                  alt={copy.photoAlt.replace("{name}", person.name)}
                  width="384"
                  height="384"
                  loading="lazy"
                  decoding="async"
                />
              </picture>
            </a>

            <div class={styles.identity}>
              <span aria-hidden="true"></span>
              <h3>{person.name}</h3>
            </div>

            <div class={styles.socials} aria-label={copy.socialsLabel.replace("{name}", person.name)}>
              <a href={person.instagram} target="_blank" rel="noreferrer" aria-label={copy.instagramLabel.replace("{name}", person.name)}>
                <Icon name="tabler:brand-instagram" size={20} aria-hidden="true" />
              </a>
              <a href={person.tiktok} target="_blank" rel="noreferrer" aria-label={copy.tiktokLabel.replace("{name}", person.name)}>
                <Icon name="tabler:brand-tiktok" size={19} aria-hidden="true" />
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
